---
import { WEEKLY_DAY_LABELS } from '../../templates/lessonTemplates';

interface DynamicTableTemplateProps {
  data: Record<string, any>;
  onChange: (data: Record<string, any>) => void;
  labelKey: string;
  defaultLabels: string[];
  highlightedCells: Array<{ type: string; index?: number; field?: string }>;
  clearHighlight: () => void;
}

const DynamicTableTemplate = ({ 
  data = {}, 
  onChange, 
  labelKey = 'phase', 
  defaultLabels = [],
  highlightedCells = [],
  clearHighlight 
}: DynamicTableTemplateProps) => {
  const d = data || {};
  const customColumns = d.customColumns || [];
  const rows = (d.rows && d.rows.length > 0)
    ? d.rows
    : defaultLabels.map((label) => ({
        [labelKey]: label,
        focus: '',
        languageTarget: '',
        assessment: ''
      }));
  const columnLabels = d.columnLabels || { focus: 'Focus', languageTarget: 'Language Target', assessment: 'Assessment' };
  const rowLabelHeader = d.rowLabelHeader ?? (labelKey.charAt(0).toUpperCase() + labelKey.slice(1));

  // Get all column keys from existing rows and custom columns
  const allColumns = Array.from(new Set([
    ...rows.flatMap(r => Object.keys(r).filter(k => k !== labelKey)),
    ...customColumns.map(c => c.key),
    'focus', 'languageTarget', 'assessment'
  ]));

  const updateRow = (index: number, field: string, value: string) => {
    const next = [...rows];
    if (!next[index]) {
      next[index] = { [labelKey]: defaultLabels[index] || `Row ${index + 1}` };
      allColumns.forEach(col => {
        next[index][col] = next[index][col] ?? '';
      });
    }
    next[index] = { ...next[index], [field]: value };
    onChange({ ...d, rows: next });
    clearHighlight?.();
  };

  const updateColumnLabel = (colKey: string, label: string) => {
    onChange({ ...d, columnLabels: { ...columnLabels, [colKey]: label } });
  };

  const updateRowLabelHeader = (value: string) => {
    onChange({ ...d, rowLabelHeader: value });
  };

  const addRow = () => {
    const newLabel = `Row ${rows.length + 1}`;
    const newRow: Record<string, any> = { [labelKey]: newLabel };
    allColumns.forEach(col => { newRow[col] = ''; });
    onChange({ ...d, rows: [...rows, newRow] });
  };

  const addColumn = () => {
    const n = allColumns.filter(k => k.startsWith('custom_')).length;
    const newKey = `custom_${n}`;
    const newRows = rows.map(r => ({ ...r, [newKey]: r[newKey] ?? '' }));
    onChange({
      ...d,
      rows: newRows,
      columnLabels: { ...columnLabels, [newKey]: `Column ${n + 1}` },
      customColumns: [...(d.customColumns || []), { key: newKey }]
    });
  };

  const deleteRow = (index: number) => {
    if (rows.length <= 1) return;
    const next = rows.filter((_, i) => i !== index);
    onChange({ ...d, rows: next });
  };

  const deleteColumn = (colKey: string) => {
    if (allColumns.length <= 1) return;
    const nextCols = allColumns.filter(k => k !== colKey);
    const nextRows = rows.map(r => {
      const copy: Record<string, any> = { ...r };
      delete copy[colKey];
      return copy;
    });
    const nextLabels: Record<string, any> = { ...columnLabels };
    delete nextLabels[colKey];
    const nextCustom = (d.customColumns || []).filter(c => c.key !== colKey);
    onChange({ ...d, rows: nextRows, columnLabels: nextLabels, customColumns: nextCustom });
  };

  const getLabelForColumn = (col: string) => {
    return columnLabels[col] ?? col.charAt(0).toUpperCase() + col.slice(1);
  };

  const displayRows = rows;

  const isHighlighted = (index: number, field: string) => {
    if (!highlightedCells || highlightedCells.length === 0) return false;
    return highlightedCells.some(c => c.type === 'row' && c.index === index && c.field === field);
  };

  const headerInputStyle = "width: 100%; padding: 8px 12px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.4); font-size: 13px; font-family: inherit; box-sizing: border-box; background: linear-gradient(135deg, #1e293b 0%, #334155 100%); color: #fff; font-weight: 600;";
  const inputStyle = "width: 100%; padding: 10px 14px; border-radius: 10px; border: 1px solid #E5E7EB; font-size: 14px; font-family: inherit; box-sizing: border-box; background-color: #ffffff;";
  const highlightedInputStyle = "border: 3px solid #DC2626; background-color: #FFEBEE; box-shadow: 0 0 0 4px rgba(220, 38, 38, 0.2);";
---

<div style="display: flex; flex-direction: column; gap: 20px;">
  <div style="overflow-x: auto;">
    <table style="width: 100%; border-collapse: collapse; font-size: 13px;">
      <thead>
        <tr style="background: linear-gradient(135deg, #1e293b 0%, #334155 100%); color: #fff; border-bottom: 2px solid #0ea5e9;">
          <th style="padding: 8px 12px; text-align: left; min-width: 100px;">
            <input
              type="text"
              value={rowLabelHeader}
              onChange={(e) => updateRowLabelHeader(e.target.value)}
              style={headerInputStyle}
              placeholder={labelKey.charAt(0).toUpperCase() + labelKey.slice(1)}
            />
          </th>
          {allColumns.map((col) => (
            <th key={col} style="padding: 8px 12px; text-align: left; min-width: 120px;">
              <div style="display: flex; align-items: center; gap: 6px;">
                <input
                  type="text"
                  value={getLabelForColumn(col)}
                  onChange={(e) => updateColumnLabel(col, e.target.value)}
                  style={`${headerInputStyle}; background: rgba(255,255,255,0.15); flex: 1; min-width: 0;`}
                  placeholder={col}
                />
                {col.startsWith('custom_') && (
                  <button
                    type="button"
                    onClick={() => deleteColumn(col)}
                    title="Delete column"
                    style="padding: 6px; border-radius: 6px; border: none; background: rgba(239,68,68,0.2); color: #ef4444; cursor: pointer; flex-shrink: 0; display: flex; align-items: center; justify-content-center;"
                  >
                    🗑️
                  </button>
                )}
              </div>
            </th>
          ))}
        </tr>
      </thead>
      <tbody>
        {displayRows.map((row: Record<string, any>, i: number) => {
          const displayLabel = row[labelKey] ?? defaultLabels[i] ?? `Row ${i + 1}`;
          return (
            <tr
              key={i}
              style={{
                borderBottom: '1px solid #E5E7EB',
                background: i % 2 === 0 ? '#fff' : '#F9FAFB'
              }}
            >
              <td style="padding: 10px; vertical-align: top; min-width: 100px;">
                <div style="display: flex; align-items: center; gap: 6px;">
                  <input
                    type="text"
                    value={displayLabel}
                    onChange={(e) => updateRow(i, labelKey, e.target.value)}
                    style={`${inputStyle}; flex: 1; min-width: 0; font-weight: 600; margin: 0; ${isHighlighted(i, labelKey) ? highlightedInputStyle : ''}`}
                    placeholder={`${labelKey} label`}
                  />
                  {i >= defaultLabels.length && (
                    <button
                      type="button"
                      onClick={() => deleteRow(i)}
                      title="Delete row"
                      style="padding: 6px; border-radius: 6px; border: none; background: rgba(239,68,68,0.2); color: #ef4444; cursor: pointer; flex-shrink: 0; display: flex; align-items: center; justify-content-center;"
                    >
                      🗑️
                    </button>
                  )}
                </div>
              </td>
              {allColumns.map((col) => (
                <td key={col} style="padding: 10px; vertical-align: top;">
                  <textarea
                    rows={2}
                    style={`${inputStyle}; min-height: 50px; min-width: 100px; margin: 0; padding: 10px 14px; resize: both; ${isHighlighted(i, col) ? highlightedInputStyle : ''}`}
                    placeholder={getLabelForColumn(col)}
                    value={(row[col] ?? '').toString()}
                    onChange={(e) => updateRow(i, col, e.target.value)}
                  />
                </td>
              ))}
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>
  <div style="display: flex; gap: 8px; flex-wrap: wrap;">
    <button
      type="button"
      onClick={addRow}
      style="display: flex; align-items: center; gap: 6px; padding: 8px 14px; border-radius: 8px; border: 1px dashed #0ea5e9; background: rgba(14, 165, 233, 0.06); color: #0ea5e9; font-size: 13px; font-weight: 600; cursor: pointer; transition: all 0.2s ease;"
    >
      ➕ Add Row
    </button>
    <button
      type="button"
      onClick={addColumn}
      style="display: flex; align-items: center; gap: 6px; padding: 8px 14px; border-radius: 8px; border: 1px dashed #0ea5e9; background: rgba(14, 165, 233, 0.06); color: #0ea5e9; font-size: 13px; font-weight: 600; cursor: pointer; transition: all 0.2s ease;"
    >
      ➕ Add Column
    </button>
  </div>
  {d.notes !== undefined && (
    <div>
      <label style="font-weight: 600; font-size: 13px; color: #374151; margin-bottom: 6px; display: block;">Notes</label>
      <textarea
        rows={2}
        style={`${inputStyle}; min-height: 60px; min-width: 200px; margin: 0; resize: both;`}
        placeholder="Notes for this plan"
        value={d.notes ?? ''}
        onChange={(e) => onChange({ ...d, notes: e.target.value })}
      />
    </div>
  )}
</div>