---
// DailyTemplate.astro - Lesson Planner Daily View Component
interface Props {
  data: Record<string, any>;
  onChange: (data: Record<string, any>) => void;
  highlightedCells: Array<{ type: string; index?: number; field?: string }>;
  clearHighlight: () => void;
}

const { data = {}, onChange, highlightedCells = [], clearHighlight } = Astro.props;

import { DAILY_STAGES, PLACEHOLDERS } from '../lib/lessonTemplates';
import { t } from '../lib/i18n';

const d = data || {};
const stages = d.stages || DAILY_STAGES.map((s) => ({
  stage: s.stage,
  method: s.method,
  teacherActions: '',
  studentActions: '',
  assessment: ''
}));

const updateStage = (index: number, field: string, value: string) => {
  const next = [...stages];
  if (!next[index]) {
    next[index] = { ...DAILY_STAGES[index], teacherActions: '', studentActions: '', assessment: '' };
  }
  next[index] = { ...next[index], [field]: value };
  onChange({ ...d, stages: next });
  clearHighlight?.();
};

const isHighlighted = (type: string, index: number | null = null, field: string | null = null) => {
  if (!highlightedCells || highlightedCells.length === 0) return false;
  if (type === 'objective') {
    return highlightedCells.some(c => c.type === 'objective');
  }
  if (type === 'materials') {
    return highlightedCells.some(c => c.type === 'materials');
  }
  if (type === 'stage' && index !== null && field !== null) {
    return highlightedCells.some(c => c.type === 'stage' && c.index === index && c.field === field);
  }
  return false;
};

const ph = PLACEHOLDERS.daily;
---

<div class="daily-template" style="display: flex; flex-direction: column; gap: 20px;">
  <!-- Objective -->
  <div>
    <label class="block text-sm font-semibold text-gray-700 mb-2">{t('lesson_planner.objective')}</label>
    <textarea
      rows={2}
      class={`w-full p-3 rounded-lg border text-sm bg-white min-h-[60px] ${
        isHighlighted('objective') 
          ? 'border-red-600 bg-red-50 shadow-[0_0_0_4px_rgba(220,38,38,0.2)]' 
          : 'border-gray-300'
      }`}
      placeholder={ph.objective}
      value={d.objective ?? ''}
      onchange={(e) => { onChange({ ...d, objective: (e.target as HTMLTextAreaElement).value }); clearHighlight?.(); }}
    />
  </div>

  <!-- Materials -->
  <div>
    <label class="block text-sm font-semibold text-gray-700 mb-2">{t('lesson_planner.materials')}</label>
    <input
      type="text"
      class={`w-full p-3 rounded-lg border text-sm bg-white ${
        isHighlighted('materials') 
          ? 'border-red-600 bg-red-50 shadow-[0_0_0_4px_rgba(220,38,38,0.2)]' 
          : 'border-gray-300'
      }`}
      placeholder={ph.materials}
      value={d.materials ?? ''}
      oninput={(e) => { onChange({ ...d, materials: (e.target as HTMLInputElement).value }); clearHighlight?.(); }}
    />
  </div>

  <!-- Stages Table -->
  <div class="overflow-x-auto">
    <table class="w-full border-collapse text-sm">
      <thead>
        <tr class="bg-gray-100 border-b-2 border-gray-200">
          <th class="p-3 text-left">{t('lesson_planner.stage')}</th>
          <th class="p-3 text-left">{t('lesson_planner.method')}</th>
          <th class="p-3 text-left">{t('lesson_planner.teacher_actions')}</th>
          <th class="p-3 text-left">{t('lesson_planner.student_actions')}</th>
          <th class="p-3 text-left">{t('lesson_planner.assessment')}</th>
        </tr>
      </thead>
      <tbody>
        {DAILY_STAGES.map((s, i) => (
          <tr class="border-b border-gray-200">
            <td class="p-3 font-semibold align-top">{s.stage}</td>
            <td class="p-3 text-gray-500 align-top">{s.method}</td>
            <td class="p-3 align-top">
              <textarea
                rows={2}
                class={`w-full p-3 rounded-lg border text-sm bg-white min-h-[50px] m-0 ${
                  isHighlighted('stage', i, 'teacherActions') 
                    ? 'border-red-600 bg-red-50 shadow-[0_0_0_4px_rgba(220,38,38,0.2)]' 
                    : 'border-gray-300'
                }`}
                placeholder={s.teacherActionsPlaceholder}
                value={(stages[i] && stages[i].teacherActions) ?? ''}
                oninput={(e) => updateStage(i, 'teacherActions', (e.target as HTMLTextAreaElement).value)}
              />
            </td>
            <td class="p-3 align-top">
              <textarea
                rows={2}
                class={`w-full p-3 rounded-lg border text-sm bg-white min-h-[50px] m-0 ${
                  isHighlighted('stage', i, 'studentActions') 
                    ? 'border-red-600 bg-red-50 shadow-[0_0_0_4px_rgba(220,38,38,0.2)]' 
                    : 'border-gray-300'
                }`}
                placeholder={s.studentActionsPlaceholder}
                value={(stages[i] && stages[i].studentActions) ?? ''}
                oninput={(e) => updateStage(i, 'studentActions', (e.target as HTMLTextAreaElement).value)}
              />
            </td>
            <td class="p-3 align-top">
              <textarea
                rows={2}
                class={`w-full p-3 rounded-lg border text-sm bg-white min-h-[50px] m-0 ${
                  isHighlighted('stage', i, 'assessment') 
                    ? 'border-red-600 bg-red-50 shadow-[0_0_0_4px_rgba(220,38,38,0.2)]' 
                    : 'border-gray-300'
                }`}
                placeholder={s.assessmentPlaceholder}
                value={(stages[i] && stages[i].assessment) ?? ''}
                oninput={(e) => updateStage(i, 'assessment', (e.target as HTMLTextAreaElement).value)}
              />
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Notes -->
  <div>
    <label class="block text-sm font-semibold text-gray-700 mb-2">{t('lesson_planner.notes')}</label>
    <textarea
      rows={2}
      class="w-full p-3 rounded-lg border border-gray-300 text-sm bg-white min-h-[60px]"
      placeholder={ph.notes}
      value={d.notes ?? ''}
      oninput={(e) => onChange({ ...d, notes: (e.target as HTMLTextAreaElement).value })}
    />
  </div>
</div>

<script>
  // Client-side interactivity for dynamic updates
  document.addEventListener('DOMContentLoaded', () => {
    // Any client-side initialization can go here
  });
</script>

<style>
  .daily-template textarea {
    resize: vertical;
    transition: all 0.2s ease;
  }
  
  .daily-template textarea:focus {
    outline: none;
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
  }
  
  .daily-template input:focus {
    outline: none;
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
  }
</style>
