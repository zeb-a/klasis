---
// DynamicTableTemplate.astro - Reusable table template for Weekly, Monthly, Yearly lesson plans
interface Props {
  data: Record<string, any>;
  onChange: (data: Record<string, any>) => void;
  labelKey: string;
  defaultLabels: string[];
  highlightedCells: Array<{ type: string; index?: number; field?: string }>;
  clearHighlight: () => void;
}

const { data = {}, onChange, labelKey = 'phase', defaultLabels = [], highlightedCells = [], clearHighlight } = Astro.props;

import { DEFAULT_COLUMN_LABELS } from '../lib/lessonTemplates';
import { t } from '../lib/i18n';

const d = data || {};
const customColumns = d.customColumns || [];

const rows = (d.rows && d.rows.length > 0)
  ? d.rows
  : defaultLabels.map((label) => ({
      [labelKey]: label,
      focus: '',
      languageTarget: '',
      assessment: ''
    }));

const columnLabels = d.columnLabels || { ...DEFAULT_COLUMN_LABELS };
const rowLabelHeader = d.rowLabelHeader ?? (labelKey.charAt(0).toUpperCase() + labelKey.slice(1));

// Get all column keys from existing rows and custom columns
const allColumnsSet = new Set<string>();
rows.forEach((r: Record<string, any>) => 
  Object.keys(r).filter(k => k !== labelKey).forEach(k => allColumnsSet.add(k))
);
customColumns.forEach((col: { key: string }) => allColumnsSet.add(col.key));
['focus', 'languageTarget', 'assessment'].forEach(k => allColumnsSet.add(k));
const allColumns = Array.from(allColumnsSet);

const updateRow = (index: number, field: string, value: string) => {
  const next = [...rows];
  if (!next[index]) {
    next[index] = { [labelKey]: defaultLabels[index] || `Row ${index + 1}` };
    allColumns.forEach(col => {
      next[index][col] = next[index][col] ?? '';
    });
  }
  next[index] = { ...next[index], [field]: value };
  onChange({ ...d, rows: next });
  clearHighlight?.();
};

const updateColumnLabel = (colKey: string, label: string) => {
  onChange({ ...d, columnLabels: { ...columnLabels, [colKey]: label } });
};

const updateRowLabelHeader = (value: string) => {
  onChange({ ...d, rowLabelHeader: value });
};

const addRow = () => {
  const newLabel = `Row ${rows.length + 1}`;
  const newRow: Record<string, any> = { [labelKey]: newLabel };
  allColumns.forEach(col => { newRow[col] = ''; });
  onChange({ ...d, rows: [...rows, newRow] });
};

const addColumn = () => {
  const n = allColumns.filter(k => k.startsWith('custom_')).length;
  const newKey = `custom_${n}`;
  const newRows = rows.map(r => ({ ...r, [newKey]: r[newKey] ?? '' }));
  onChange({
    ...d,
    rows: newRows,
    columnLabels: { ...columnLabels, [newKey]: `Column ${n + 1}` },
    customColumns: [...(d.customColumns || []), { key: newKey }]
  });
};

const deleteRow = (index: number) => {
  if (rows.length <= 1) return;
  const next = rows.filter((_: any, i: number) => i !== index);
  onChange({ ...d, rows: next });
};

const deleteColumn = (colKey: string) => {
  if (allColumns.length <= 1) return;
  const nextCols = allColumns.filter(k => k !== colKey);
  const nextRows = rows.map((r: Record<string, any>) => {
    const copy = { ...r };
    delete copy[colKey];
    return copy;
  });
  const nextLabels: Record<string, string> = { ...columnLabels };
  delete nextLabels[colKey];
  const nextCustom = (d.customColumns || []).filter((c: { key: string }) => c.key !== colKey);
  onChange({ ...d, rows: nextRows, columnLabels: nextLabels, customColumns: nextCustom });
};

const getLabelForColumn = (col: string) => {
  return columnLabels[col] ?? DEFAULT_COLUMN_LABELS[col] ?? (col.charAt(0).toUpperCase() + col.slice(1));
};

const displayRows = rows;

const isHighlighted = (index: number, field: string) => {
  if (!highlightedCells || highlightedCells.length === 0) return false;
  return highlightedCells.some(c => c.type === 'row' && c.index === index && c.field === field);
};

const getLabelKeyDisplay = (row: Record<string, any>) => {
  return row[labelKey] || row.day || row.phase || row.section || `Row ${displayRows.indexOf(row) + 1}`;
};
---

<div class="dynamic-table-template" style="display: flex; flex-direction: column; gap: 20px;">
  <div class="overflow-x-auto">
    <table class="w-full border-collapse text-sm">
      <thead>
        <tr class="text-white border-b-2 border-sky-500" style="background: linear-gradient(135deg, #1e293b 0%, #334155 100%);">
          <th class="p-2 text-left min-w-[100px]">
            <input
              type="text"
              value={rowLabelHeader}
              oninput={(e) => updateRowLabelHeader((e.target as HTMLInputElement).value)}
              class="w-full p-2 rounded-lg border border-white/40 font-semibold bg-[linear-gradient(135deg,#1e293b_0%,#334155_100%)] text-white"
              placeholder={labelKey.charAt(0).toUpperCase() + labelKey.slice(1)}
            />
          </th>
          {allColumns.map((col) => (
            <th class="p-2 text-left min-w-[120px]">
              <div class="flex items-center gap-2">
                <input
                  type="text"
                  value={getLabelForColumn(col)}
                  oninput={(e) => updateColumnLabel(col, (e.target as HTMLInputElement).value)}
                  class="flex-1 p-2 rounded-lg border border-white/40 font-semibold bg-transparent text-white placeholder-white/60"
                  placeholder={getLabelForColumn(col)}
                />
                {allColumns.length > 1 && (
                  <button
                    onclick={() => deleteColumn(col)}
                    class="p-1 rounded hover:bg-white/20 transition-colors"
                    title="Delete column"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M3 6h18"></path>
                      <path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path>
                      <path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path>
                    </svg>
                  </button>
                )}
              </div>
            </th>
          ))}
          <th class="p-2 w-[50px]"></th>
        </tr>
      </thead>
      <tbody>
        {displayRows.map((row: Record<string, any>, rowIndex: number) => (
          <tr class="border-b border-gray-200 hover:bg-gray-50 transition-colors">
            <td class="p-2 font-semibold align-top">
              <span class="text-gray-700">{getLabelKeyDisplay(row)}</span>
            </td>
            {allColumns.map((col) => (
              <td class="p-2 align-top">
                <textarea
                  rows={2}
                  class={`w-full p-2 rounded-lg border text-sm bg-white min-h-[50px] resize-y ${
                    isHighlighted(rowIndex, col)
                      ? 'border-red-600 bg-red-50 shadow-[0_0_0_4px_rgba(220,38,38,0.2)]'
                      : 'border-gray-300'
                  }`}
                  placeholder={getLabelForColumn(col)}
                  value={row[col] ?? ''}
                  oninput={(e) => updateRow(rowIndex, col, (e.target as HTMLTextAreaElement).value)}
                />
              </td>
            ))}
            <td class="p-2 align-top">
              {rows.length > 1 && (
                <button
                  onclick={() => deleteRow(rowIndex)}
                  class="p-1.5 rounded-lg text-gray-400 hover:text-red-600 hover:bg-red-50 transition-all"
                  title="Delete row"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 6h18"></path>
                    <path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path>
                    <path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path>
                  </svg>
                </button>
              )}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Action Buttons -->
  <div class="flex gap-3">
    <button
      onclick={() => addRow()}
      class="flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 text-white hover:bg-blue-700 transition-colors font-medium"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14"></path>
        <path d="M12 5v14"></path>
      </svg>
      Add Row
    </button>
    <button
      onclick={() => addColumn()}
      class="flex items-center gap-2 px-4 py-2 rounded-lg bg-green-600 text-white hover:bg-green-700 transition-colors font-medium"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 5v14"></path>
        <path d="M5 12h14"></path>
      </svg>
      Add Column
    </button>
  </div>

  <!-- Notes Section -->
  <div>
    <label class="block text-sm font-semibold text-gray-700 mb-2">{t('lesson_planner.notes')}</label>
    <textarea
      rows={3}
      class="w-full p-3 rounded-lg border border-gray-300 text-sm bg-white resize-y"
      placeholder="Additional notes..."
      value={d.notes ?? ''}
      oninput={(e) => onChange({ ...d, notes: (e.target as HTMLTextAreaElement).value })}
    />
  </div>
</div>

<style>
  .dynamic-table-template textarea {
    resize: vertical;
    transition: all 0.2s ease;
  }
  
  .dynamic-table-template textarea:focus {
    outline: none;
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
  }
  
  .dynamic-table-template input:focus {
    outline: none;
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
  }
</style>
