--- astro-rewrite/src/components/teacher/TeacherRailCollapsibleTools.astro (原始)


+++ astro-rewrite/src/components/teacher/TeacherRailCollapsibleTools.astro (修改后)
---
/**
 * Teacher Rail Collapsible Tools Component for Astro
 * Collapsible tools block for the teacher class rail (lesson planner, export backup).
 *
 * Features:
 * - Lesson planner access
 * - Data export/backup functionality
 * - Profile editing (when no class selected)
 * - Logout with confirmation
 */

interface Props {
        user?: any;
        classes?: any[];
        railCollapsed?: boolean;
        includeAccountInRail?: boolean;
}

const {
        user,
        classes = [],
        railCollapsed = false,
        includeAccountInRail = false
} = Astro.props;
---

<style>
        .tools-container {
                border-top: 1px solid rgba(148,163,184,0.15);
                padding: 12px;
                display: flex;
                flex-direction: column;
                gap: 8px;
                flex-shrink: 0;
        }

        .tools-container.collapsed {
                padding: 8px;
        }

        .toggle-btn {
                display: flex;
                align-items: center;
                justify-content: space-between;
                width: 100%;
                padding: 10px 12px;
                border-radius: 12px;
                border: 1px solid rgba(148,163,184,0.18);
                background: rgba(248,250,252,0.95);
                cursor: pointer;
                color: #64748b;
                font-weight: 700;
                font-size: 11px;
                letter-spacing: 0.05em;
                text-transform: uppercase;
                gap: 8px;
                transition: all 0.2s ease;
        }

        .toggle-btn.collapsed {
                justify-content: center;
                padding: 8px 4px;
                font-size: 0;
        }

        .toggle-btn:hover {
                background: rgba(241,245,249,0.95);
        }

        .tool-btn {
                display: flex;
                align-items: center;
                justify-content: flex-start;
                gap: 10px;
                width: 100%;
                padding: 10px 12px;
                border-radius: 12px;
                border: 1px solid rgba(148,163,184,0.2);
                background: rgba(255,255,255,0.9);
                color: #0f172a;
                font-weight: 600;
                font-size: 13px;
                cursor: pointer;
                box-sizing: border-box;
                transition: all 0.2s ease;
        }

        .tool-btn:hover {
                transform: scale(1.02);
                box-shadow: 0 4px 12px rgba(15,23,42,0.12);
        }

        .tool-btn.icon-only {
                justify-content: center;
                width: 44px;
                height: 40px;
                padding: 0;
        }

        .tool-btn.danger {
                color: #DC2626;
                border-color: rgba(220,38,38,0.35);
        }

        .tool-btn.danger:hover {
                box-shadow: 0 4px 12px rgba(220,38,38,0.2);
        }

        .tools-list {
                display: flex;
                flex-direction: column;
                gap: 6px;
        }

        .tools-list.hidden {
                display: none;
        }

        /* Dark mode */
        :root.dark .tools-container {
                border-top-color: rgba(148,163,184,0.15);
        }

        :root.dark .toggle-btn {
                background: rgba(30,41,59,0.4);
                border-color: rgba(148,163,184,0.18);
                color: #94a3b8;
        }

        :root.dark .toggle-btn:hover {
                background: rgba(30,41,59,0.5);
        }

        :root.dark .tool-btn {
                background: rgba(30,41,59,0.55);
                border-color: rgba(148,163,184,0.2);
                color: #e2e8f0;
        }

        :root.dark .tool-btn:hover {
                box-shadow: 0 6px 14px rgba(0,0,0,0.35);
        }

        /* Modal overlay */
        .modal-overlay {
                position: fixed;
                inset: 0;
                background: rgba(15,23,42,0.25);
                z-index: 400000;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 16px;
        }

        .modal-content {
                background: #fff;
                border-radius: 20px;
                padding: 24px;
                max-width: 360px;
                width: 100%;
        }

        :root.dark .modal-content {
                background: #1e293b;
        }

        .modal-text {
                margin: 0 0 16px;
                font-weight: 700;
        }

        .modal-actions {
                display: flex;
                gap: 10px;
        }

        .modal-btn {
                flex: 1;
                padding: 12px;
                border-radius: 12px;
                border: none;
                font-weight: 700;
                cursor: pointer;
                transition: all 0.2s ease;
        }

        .modal-btn.confirm {
                background: #DC2626;
                color: #fff;
        }

        .modal-btn.confirm:hover {
                background: #b91c1c;
        }

        .modal-btn.cancel {
                background: transparent;
                border: 1px solid #e5e7eb;
                color: inherit;
        }

        .modal-btn.cancel:hover {
                background: rgba(0,0,0,0.05);
        }
</style>

<div
        class="tools-container"
        class:collapsed={railCollapsed}
        data-teacher-rail-tools
>
        <button
                type="button"
                class="toggle-btn"
                class:collapsed={railCollapsed}
                id="tools-toggle-btn"
                aria-expanded="false"
        >
                <span data-tool-label>Workspace Tools</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="toggle-icon">
                        <path d="m6 9 6 6 6-6"/>
                </svg>
        </button>

        <div class="tools-list hidden" id="tools-list">
                <button
                        type="button"
                        class="tool-btn"
                        class:icon-only={railCollapsed}
                        id="lesson-planner-btn"
                >
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/>
                        </svg>
                        <span data-btn-label>Lesson Planner</span>
                </button>

                <button
                        type="button"
                        class="tool-btn"
                        class:icon-only={railCollapsed}
                        id="export-backup-btn"
                >
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                                <polyline points="7 10 12 15 17 10"/>
                                <line x1="12" x2="12" y1="15" y2="3"/>
                        </svg>
                        <span data-btn-label>Export Backup</span>
                </button>

                {includeAccountInRail && user && (
                        <>
                                <button
                                        type="button"
                                        class="tool-btn"
                                        class:icon-only={railCollapsed}
                                        id="edit-profile-btn"
                                >
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/>
                                                <circle cx="12" cy="7" r="4"/>
                                        </svg>
                                        <span data-btn-label>Edit Profile</span>
                                </button>

                                <button
                                        type="button"
                                        class="tool-btn danger"
                                        class:icon-only={railCollapsed}
                                        id="logout-btn"
                                >
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                                                <polyline points="16 17 21 12 16 7"/>
                                                <line x1="21" x2="9" y1="12" y2="12"/>
                                        </svg>
                                        <span data-btn-label>Logout</span>
                                </button>
                        </>
                )}
        </div>
</div>

<!-- Logout Confirmation Modal -->
<div class="modal-overlay hidden" id="logout-modal" role="dialog" aria-modal="true">
        <div class="modal-content" onclick="event.stopPropagation()">
                <p class="modal-text">Are you sure you want to logout?</p>
                <div class="modal-actions">
                        <button type="button" class="modal-btn confirm" id="confirm-logout-btn">Yes</button>
                        <button type="button" class="modal-btn cancel" id="cancel-logout-btn">No</button>
                </div>
        </div>
</div>

<script>
(function() {
        const isDark = () => document.documentElement.classList.contains('dark');

        // Elements
        const toggleBtn = document.getElementById('tools-toggle-btn') as HTMLButtonElement;
        const toolsList = document.getElementById('tools-list') as HTMLDivElement;
        const toggleIcon = toggleBtn?.querySelector('.toggle-icon') as SVGElement;
        const logoutModal = document.getElementById('logout-modal') as HTMLDivElement;
        const logoutBtn = document.getElementById('logout-btn') as HTMLButtonElement;
        const confirmLogoutBtn = document.getElementById('confirm-logout-btn') as HTMLButtonElement;
        const cancelLogoutBtn = document.getElementById('cancel-logout-btn') as HTMLButtonElement;
        const lessonPlannerBtn = document.getElementById('lesson-planner-btn') as HTMLButtonElement;
        const exportBackupBtn = document.getElementById('export-backup-btn') as HTMLButtonElement;
        const editProfileBtn = document.getElementById('edit-profile-btn') as HTMLButtonElement;

        const railCollapsedStr = JSON.stringify(railCollapsed);
        const classesStr = JSON.stringify(classes);

        const railCollapsed = railCollapsedStr;
        const classesData = classesStr;

        let expanded = false;

        function updateUI() {
                if (!toggleBtn || !toolsList || !toggleIcon) return;

                // Update collapsed state
                if (railCollapsed) {
                        toggleBtn.classList.add('collapsed');
                        toggleBtn.setAttribute('aria-expanded', 'false');
                } else {
                        toggleBtn.classList.remove('collapsed');
                }

                // Update icon rotation
                if (expanded) {
                        toggleIcon.style.transform = 'rotate(180deg)';
                        toolsList.classList.remove('hidden');
                        toggleBtn.setAttribute('aria-expanded', 'true');
                } else {
                        toggleIcon.style.transform = 'rotate(0deg)';
                        toolsList.classList.add('hidden');
                        toggleBtn.setAttribute('aria-expanded', 'false');
                }

                // Update button labels
                const labels = document.querySelectorAll('[data-btn-label]');
                labels.forEach(label => {
                        const btn = label.parentElement as HTMLButtonElement;
                        if (railCollapsed) {
                                btn.classList.add('icon-only');
                        } else {
                                btn.classList.remove('icon-only');
                        }
                });
        }

        // Toggle tools visibility
        toggleBtn?.addEventListener('click', () => {
                expanded = !expanded;
                updateUI();
        });

        // Export backup functionality
        exportBackupBtn?.addEventListener('click', () => {
                try {
                        const backupData = {
                                version: '1.0',
                                timestamp: new Date().toISOString(),
                                classes: Array.isArray(classes) ? classes : []
                        };
                        const blob = new Blob([JSON.stringify(backupData, null, 2)], { type: 'application/json' });
                        const url = URL.createObjectURL(blob);
                        const link = document.createElement('a');
                        link.href = url;
                        link.download = `klasiz_backup_${new Date().toISOString().split('T')[0]}.json`;
                        document.body.appendChild(link);
                        link.click();
                        document.body.removeChild(link);
                        URL.revokeObjectURL(url);

                        // Show success message
                        window.dispatchEvent(new CustomEvent('toast', {
                                detail: { message: 'Backup downloaded successfully', type: 'success' }
                        }));
                } catch (err) {
                        window.dispatchEvent(new CustomEvent('toast', {
                                detail: { message: 'Failed to download backup', type: 'error' }
                        }));
                }
        });

        // Logout functionality
        logoutBtn?.addEventListener('click', () => {
                logoutModal?.classList.remove('hidden');
        });

        cancelLogoutBtn?.addEventListener('click', () => {
                logoutModal?.classList.add('hidden');
        });

        confirmLogoutBtn?.addEventListener('click', () => {
                logoutModal?.classList.add('hidden');
                window.dispatchEvent(new CustomEvent('teacher-logout'));
        });

        // Close modal on overlay click
        logoutModal?.addEventListener('click', (e) => {
                if (e.target === logoutModal) {
                        logoutModal.classList.add('hidden');
                }
        });

        // Lesson planner button
        lessonPlannerBtn?.addEventListener('click', () => {
                window.location.href = '/lesson-planner';
        });

        // Edit profile button
        editProfileBtn?.addEventListener('click', () => {
                window.dispatchEvent(new CustomEvent('open-profile-modal'));
        });

        // Initialize
        updateUI();
})();
</script>
