---
interface Props {
    icon: any;
    variant?: 'dock' | 'sidebar';
    forceLabelRow?: boolean;
    label?: string;
    isActive?: boolean;
    badge?: number | string;
    style?: any;
    onClick?: () => void;
    [key: string]: any;
}

const { icon: Icon, variant = 'dock', forceLabelRow = false, label = '', isActive = false, badge = null, style = {}, onClick, ...props } = Astro.props;
---

<button 
    onClick={onClick}
    class="flex items-center gap-3 p-3 rounded-lg transition-all duration-200 hover:bg-indigo-100"
    class:list={[
        variant === 'dock' ? 'w-12 h-12 justify-center' : 'w-full px-4 py-3',
        isActive ? 'bg-indigo-100 text-indigo-700' : 'text-gray-600 hover:text-gray-900',
        forceLabelRow ? 'flex-row' : variant === 'dock' ? 'flex-col' : 'flex-row'
    ]}
    style={style}
    {...props}
>
    <Icon class="w-5 h-5" />
    <span x-show={variant === 'sidebar' || forceLabelRow} class="font-medium text-sm">{label}</span>
    
    {badge && (
        <span class="absolute top-1 right-1 bg-red-500 text-white text-xs rounded-full w-5 h-5 flex items-center justify-center">
            {badge}
        </span>
    )}
</button>
