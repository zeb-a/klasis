---
/**
 * Parent Portal Component for Astro
 * Allows parents to view their child's progress using an access code
 */

interface StudentData {
    studentId: string;
    studentName: string;
    classData: any;
}

interface Props {
    onBack?: () => void;
    initialStudentData?: StudentData | null;
}

const { onBack, initialStudentData = null } = Astro.props;
---

<div x-data="parentPortal({ initialStudentData: {initialStudentData} })" class="parent-portal-container">
    <!-- Login View -->
    <div x-show="!studentData" class="login-view">
        <div class="login-card">
            <div class="icon-circle">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
            </div>
            <h2>Parent Access</h2>
            <p class="subtitle">Enter your 5-digit parent code</p>
            
            <form @submit.prevent="handleLogin">
                <input 
                    type="text" 
                    x-model="accessCode" 
                    placeholder="00000" 
                    maxlength="5"
                    class="code-input"
                    @input="accessCode = accessCode.toUpperCase().replace(/[^A-Z0-9]/g, '')"
                />
                <div x-show="error" class="error-message" x-text="error"></div>
                <button type="submit" class="submit-btn" :disabled="loading">
                    <span x-show="!loading">Enter Portal</span>
                    <span x-show="loading">Verifying...</span>
                </button>
                <button type="button" @click="handleBack" class="cancel-btn">Cancel</button>
            </form>
        </div>
    </div>

    <!-- Reports View -->
    <div x-show="studentData" class="reports-view" style="display: none;">
        <div class="top-bar">
            <div class="student-info">
                <h2 x-text="studentData?.studentName || 'Student'"></h2>
                <p>Student Progress Report</p>
            </div>
            <button @click="logout" class="logout-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                Logout
            </button>
        </div>
        
        <div class="report-container">
            <div class="report-placeholder">
                <h3>Progress Report for <span x-text="studentData?.studentName"></span></h3>
                <p>Class: <span x-text="studentData?.classData?.name || 'N/A'"></span></p>
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-value">--</div>
                        <div class="stat-label">Total Points</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value">--</div>
                        <div class="stat-label">Assignments</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value">--</div>
                        <div class="stat-label">Level</div>
                    </div>
                </div>
                <p class="note">Full report data would be loaded from API</p>
            </div>
        </div>
    </div>
</div>

<style>
    .parent-portal-container {
        min-height: 100vh;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    }

    .login-view {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        background: #F8FAFC;
    }

    .login-card {
        background: #fff;
        padding: 50px;
        border-radius: 32px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.05);
        text-align: center;
        width: 420px;
        max-width: 90vw;
        border: 1px solid #E2E8F0;
    }

    .icon-circle {
        width: 70px;
        height: 70px;
        background: #FFF1F2;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        color: #EF4444;
    }

    .login-card h2 {
        font-weight: 900;
        margin-bottom: 10px;
        font-size: 24px;
        color: #1E293B;
    }

    .subtitle {
        color: #64748B;
        margin-bottom: 30px;
        font-size: 14px;
    }

    .code-input {
        font-size: 40px;
        text-align: center;
        letter-spacing: 8px;
        width: 100%;
        padding: 16px;
        border-radius: 16px;
        border: 2px solid #F1F5F9;
        background: #F8FAFC;
        margin-bottom: 20px;
        font-weight: 900;
        outline: none;
        transition: border-color 0.2s;
    }

    .code-input:focus {
        border-color: #EF4444;
    }

    .error-message {
        color: #EF4444;
        font-size: 14px;
        font-weight: 700;
        margin-bottom: 15px;
    }

    .submit-btn {
        width: 100%;
        background: #2D2D30;
        color: #fff;
        padding: 18px;
        border-radius: 16px;
        border: none;
        font-weight: 800;
        cursor: pointer;
        font-size: 17px;
        transition: all 0.2s;
    }

    .submit-btn:hover:not(:disabled) {
        background: #1a1a1d;
        transform: translateY(-2px);
    }

    .submit-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .cancel-btn {
        width: 100%;
        background: none;
        border: none;
        color: #64748B;
        margin-top: 20px;
        cursor: pointer;
        font-weight: 700;
        font-size: 14px;
    }

    .cancel-btn:hover {
        color: #1E293B;
    }

    .reports-view {
        background: #F8FAFC;
        min-height: 100vh;
        padding: 20px;
    }

    .top-bar {
        max-width: 1000px;
        margin: 0 auto 30px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .student-info h2 {
        font-size: 26px;
        font-weight: 900;
        color: #1E293B;
        margin: 0;
    }

    .student-info p {
        color: #64748B;
        margin: 5px 0 0;
        font-weight: 600;
        font-size: 14px;
    }

    .logout-btn {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 14px 28px;
        border-radius: 16px;
        background: #fff;
        border: 1px solid #E2E8F0;
        font-weight: 800;
        cursor: pointer;
        color: #64748B;
        font-size: 15px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .logout-btn:hover {
        transform: translateY(-2px);
        background: #FFF1F2;
        color: #EF4444;
        box-shadow: 0 10px 15px -3px rgba(239, 68, 68, 0.1);
    }

    .report-container {
        max-width: 1000px;
        margin: 0 auto;
        background: #fff;
        border-radius: 32px;
        border: 1px solid #E2E8F0;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.02);
        padding: 40px;
    }

    .report-placeholder {
        text-align: center;
    }

    .report-placeholder h3 {
        font-size: 24px;
        font-weight: 800;
        color: #1E293B;
        margin-bottom: 10px;
    }

    .report-placeholder p {
        color: #64748B;
        margin-bottom: 30px;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 20px;
        margin: 30px 0;
    }

    .stat-card {
        background: #F8FAFC;
        padding: 24px;
        border-radius: 16px;
        border: 1px solid #E2E8F0;
    }

    .stat-value {
        font-size: 32px;
        font-weight: 900;
        color: #16A34A;
        margin-bottom: 8px;
    }

    .stat-label {
        font-size: 13px;
        color: #64748B;
        font-weight: 600;
    }

    .note {
        font-size: 13px;
        color: #94A3B8;
        margin-top: 20px;
    }

    @media (max-width: 640px) {
        .login-card {
            padding: 30px 20px;
        }
        
        .code-input {
            font-size: 28px;
            letter-spacing: 4px;
        }
        
        .top-bar {
            flex-direction: column;
            gap: 15px;
            text-align: center;
        }
        
        .logout-btn {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<script>
    function parentPortal({ initialStudentData }) {
        return {
            accessCode: '',
            studentData: initialStudentData,
            error: '',
            loading: false,

            init() {
                // Check for saved session
                const savedSession = localStorage.getItem('klasiz_parent_session');
                if (savedSession) {
                    try {
                        this.studentData = JSON.parse(savedSession);
                    } catch (e) {
                        localStorage.removeItem('klasiz_parent_session');
                    }
                }
            },

            async handleLogin() {
                this.error = '';
                this.loading = true;

                if (!this.accessCode || this.accessCode.length !== 5) {
                    this.error = 'Please enter a valid 5-digit code';
                    this.loading = false;
                    return;
                }

                try {
                    // In production, this would call your API
                    // const response = await fetch(`/api/parent/${this.accessCode}`);
                    // const data = await response.json();
                    
                    // Simulated response for demo
                    await new Promise(resolve => setTimeout(resolve, 1000));
                    
                    // For demo purposes, create mock data
                    this.studentData = {
                        studentId: 'demo-student',
                        studentName: 'Demo Student',
                        classData: {
                            name: 'Class 3A',
                            id: 'demo-class'
                        }
                    };

                    // Save session
                    localStorage.setItem('klasiz_parent_session', JSON.stringify(this.studentData));
                } catch (err) {
                    this.error = 'Connection error. Please try again.';
                } finally {
                    this.loading = false;
                }
            },

            handleBack() {
                if (onBack) {
                    onBack();
                } else {
                    window.history.back();
                }
            },

            logout() {
                this.studentData = null;
                this.accessCode = '';
                localStorage.removeItem('klasiz_parent_session');
            }
        };
    }
</script>
