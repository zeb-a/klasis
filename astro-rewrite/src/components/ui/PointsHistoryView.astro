    const filterStudentSelect = document.getElementById('filter-student');
    const filterDateSelect = document.getElementById('filter-date');
    const clearBtn = document.getElementById('clear-btn');
    const eventsList = document.getElementById('events-list');
    const emptyState = document.getElementById('empty-state');
    const confirmOverlay = document.getElementById('confirm-overlay');
    const confirmCancel = document.getElementById('confirm-cancel');
    const confirmDelete = document.getElementById('confirm-delete');
    const statWow = document.getElementById('stat-wow');
    const statNono = document.getElementById('stat-nono');
    const statLucky = document.getElementById('stat-lucky');
    
    // Format date
    function formatDate(timestamp) {
      const date = new Date(timestamp);
      const now = new Date();
      const diffMs = now.getTime() - date.getTime();
      const diffMins = Math.floor(diffMs / 60000);
      const diffHours = Math.floor(diffMs / 3600000);
      
      if (diffMins < 1) return 'Just now';
      if (diffMins < 60) return `${diffMins}m ago`;
      if (diffHours < 24) return `${diffHours}h ago`;
      
      return date.toLocaleDateString('en-US', {
        weekday: 'short',
        month: 'short',
        day: 'numeric',
        hour: 'numeric',
        minute: '2-digit',
        hour12: true
      });
    }
    
    // Apply filters
    function getFilteredEvents() {
      let filtered = [...allEvents];
      
      // Filter by type
      if (filterType !== 'all') {
        if (filterType === 'lucky') {
          filtered = filtered.filter(e => e.label === 'Lucky Draw Winner');
        } else {
          filtered = filtered.filter(e => e.type === filterType);
        }
      }
      
      // Filter by student
      if (filterStudent !== 'all') {
        filtered = filtered.filter(e => String(e.studentId) === String(filterStudent));
      }
      
      // Filter by date range
      if (dateRange !== 'all') {
        const now = new Date();
        const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
        
        filtered = filtered.filter(e => {
          const eventDate = new Date(e.timestamp);
          
          switch (dateRange) {
            case 'today':
              return eventDate >= today;
            case 'week':
              const weekAgo = new Date(today);
              weekAgo.setDate(weekAgo.getDate() - 7);
              return eventDate >= weekAgo;
            case 'month':
              const monthAgo = new Date(today);
              monthAgo.setMonth(monthAgo.getMonth() - 1);
              return eventDate >= monthAgo;
            default:
              return true;
          }
        });
      }
      
      return filtered;
    }
    
    // Render events
    function renderEvents() {
      const filtered = getFilteredEvents();
      
      if (filtered.length === 0) {
        eventsList.innerHTML = '';
        emptyState.classList.remove('hidden');
        return;
      }
      
      emptyState.classList.add('hidden');
      
      eventsList.innerHTML = filtered.map(event => {
        const isPositive = event.pts > 0;
        const pointsClass = isPositive ? 'positive' : 'negative';
        const pointsSign = isPositive ? '+' : '';
        
        return `
          <div class="events-list-item">
            <img src="${event.studentAvatar}" alt="" class="event-avatar" />
            <div class="event-content">
              <div class="event-header">
                <span class="event-student-name">${event.studentName}</span>
                <span class="event-points ${pointsClass}">${pointsSign}${event.pts}</span>
              </div>
              <div class="event-label">${event.label}</div>
              <div class="event-date">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                ${formatDate(event.timestamp)}
              </div>
            </div>
          </div>
        `;
      }).join('');
    }
    
    // Handle refresh
    refreshBtn?.addEventListener('click', async () => {
      if (refreshing) return;
      
      refreshing = true;
      refreshBtn.classList.add('refreshing');
      
      try {
        await refreshClasses();
        window.dispatchEvent(new CustomEvent('toast', {
          detail: { message: 'History refreshed!', type: 'success' }
        }));
      } catch (err) {
        window.dispatchEvent(new CustomEvent('toast', {
          detail: { message: 'Failed to refresh', type: 'error' }
        }));
      } finally {
        refreshing = false;
        refreshBtn.classList.remove('refreshing');
      }
    });
    
    // Handle filters
    filterTypeSelect?.addEventListener('change', (e) => {
      filterType = e.target.value;
      renderEvents();
    });
    
    filterStudentSelect?.addEventListener('change', (e) => {
      filterStudent = e.target.value;
      renderEvents();
    });
    
    filterDateSelect?.addEventListener('change', (e) => {
      dateRange = e.target.value;
      renderEvents();
    });
    
    // Handle clear button
    clearBtn?.addEventListener('click', () => {
      clearTarget = 'all';
      showConfirmModal = true;
      confirmOverlay.classList.remove('hidden');
    });
    
    // Handle confirm cancel
    confirmCancel?.addEventListener('click', () => {
      showConfirmModal = false;
      confirmOverlay.classList.add('hidden');
    });
    
    // Handle confirm delete
    confirmDelete?.addEventListener('click', async () => {
      if (clearing) return;
      
      clearing = true;
      showConfirmModal = false;
      confirmOverlay.classList.add('hidden');
      
      try {
        // Dispatch clear event
        window.dispatchEvent(new CustomEvent('clear-history', {
          detail: { target: clearTarget }
        }));
        
        window.dispatchEvent(new CustomEvent('toast', {
          detail: { message: 'History cleared successfully!', type: 'success' }
        }));
      } catch (err) {
        window.dispatchEvent(new CustomEvent('toast', {
          detail: { message: 'Failed to clear history', type: 'error' }
        }));
      } finally {
        clearing = false;
      }
    });
    
    // Close handlers
    closeBtn?.addEventListener('click', onClose);
    
    overlay?.addEventListener('click', (e) => {
      if (e.target === overlay) {
        onClose();
      }
    });
    
    modalContent?.addEventListener('click', (e) => {
      e.stopPropagation();
    });
    
    // Placeholder function
    window.onClose = function() {
      window.dispatchEvent(new CustomEvent('history-modal-close'));
    };
    
    window.refreshClasses = async function() {
      // In real usage, this would be provided by parent component
      return Promise.resolve();
    };
    
    // Initialize
    renderEvents();
  })();
</script>
