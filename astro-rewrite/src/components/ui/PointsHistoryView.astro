---
import type { ClassData, Student } from '../types';

interface Props {
  activeClass: ClassData;
  onClose: () => void;
  refreshClasses: () => Promise<void>;
}

const { activeClass, onClose, refreshClasses } = Astro.props;

// Build-time data preparation
const students = activeClass.students || [];
const allEvents: any[] = [];

(students as Student[]).forEach(student => {
  if (student.history && Array.isArray(student.history)) {
    student.history.forEach(event => {
      allEvents.push({
        ...event,
        studentId: student.id,
        studentName: student.name,
        studentAvatar: student.avatar,
        studentGender: student.gender
      });
    });
  }
});

// Sort by timestamp (newest first)
allEvents.sort((a, b) => new Date(b.timestamp).getTime() - new Date(a.timestamp).getTime());

// Calculate stats
let totalWow = 0;
let totalNono = 0;
let totalLucky = 0;

allEvents.forEach(event => {
  if (event.pts > 0) {
    if (event.label === 'Lucky Draw Winner') {
      totalLucky += event.pts;
    } else {
      totalWow += event.pts;
    }
  } else {
    totalNono += event.pts;
  }
});
