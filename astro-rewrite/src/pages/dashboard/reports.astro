---
import MainLayout from '../../layouts/MainLayout.astro';
import { ArrowLeft, TrendingUp, TrendingDown, Users, Award, BarChart3, PieChart, Calendar, Download, Filter, ChevronDown, Activity, Target, Star } from 'lucide-react';
---

<MainLayout title="Reports - Klasiz.fun" description="Class analytics and reports">
    <div x-data="reportsPage()" class="min-h-screen bg-gray-50">
        <!-- Loading State -->
        <div x-show="loading" class="fixed inset-0 bg-white flex items-center justify-center z-50">
            <div class="text-center">
                <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-green-600 mx-auto mb-4"></div>
                <p class="text-gray-600">Loading reports...</p>
            </div>
        </div>
        
        <!-- Header -->
        <header class="bg-white border-b border-gray-200 px-4 py-3">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-4">
                    <button @click="window.history.back()" class="p-2 rounded-lg hover:bg-gray-100">
                        <ArrowLeft class="w-5 h-5" />
                    </button>
                    <div>
                        <h1 class="text-xl font-bold text-gray-900">Reports & Analytics</h1>
                        <p class="text-sm text-gray-500" x-text="currentClass ? currentClass.name : 'Loading...'"></p>
                    </div>
                </div>
                
                <div class="flex items-center gap-2">
                    <!-- Date Range Filter -->
                    <div class="relative" x-data="{ dateRangeOpen: false }">
                        <button @click="dateRangeOpen = !dateRangeOpen" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 flex items-center gap-2">
                            <Calendar class="w-4 h-4" />
                            <span x-text="dateRangeLabel"></span>
                            <ChevronDown class="w-4 h-4" />
                        </button>
                        
                        <div x-show="dateRangeOpen" @click.away="dateRangeOpen = false" 
                             class="absolute right-0 top-full mt-2 w-48 bg-white rounded-lg shadow-lg border border-gray-200 py-2 z-50">
                            <button @click="setDateRange('today')" class="w-full px-4 py-2 text-left text-sm text-gray-700 hover:bg-gray-50">
                                Today
                            </button>
                            <button @click="setDateRange('week')" class="w-full px-4 py-2 text-left text-sm text-gray-700 hover:bg-gray-50">
                                This Week
                            </button>
                            <button @click="setDateRange('month')" class="w-full px-4 py-2 text-left text-sm text-gray-700 hover:bg-gray-50">
                                This Month
                            </button>
                            <button @click="setDateRange('term')" class="w-full px-4 py-2 text-left text-sm text-gray-700 hover:bg-gray-50">
                                This Term
                            </button>
                        </div>
                    </div>
                    
                    <button @click="exportReport()" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 flex items-center gap-2">
                        <Download class="w-4 h-4" />
                        Export
                    </button>
                </div>
            </div>
        </header>

        <!-- Main Content -->
        <main class="p-4 space-y-6">
            <!-- Overview Cards -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                <div class="bg-white rounded-lg border border-gray-200 p-4">
                    <div class="flex items-center justify-between mb-2">
                        <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
                            <Users class="w-5 h-5 text-green-600" />
                        </div>
                        <div class="flex items-center gap-1 text-green-600">
                            <TrendingUp class="w-4 h-4" />
                            <span class="text-sm font-medium">+12%</span>
                        </div>
                    </div>
                    <div class="text-2xl font-bold text-gray-900" x-text="totalStudents"></div>
                    <div class="text-sm text-gray-500">Total Students</div>
                </div>
                
                <div class="bg-white rounded-lg border border-gray-200 p-4">
                    <div class="flex items-center justify-between mb-2">
                        <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
                            <Award class="w-5 h-5 text-blue-600" />
                        </div>
                        <div class="flex items-center gap-1 text-blue-600">
                            <TrendingUp class="w-4 h-4" />
                            <span class="text-sm font-medium">+8%</span>
                        </div>
                    </div>
                    <div class="text-2xl font-bold text-gray-900" x-text="averagePoints"></div>
                    <div class="text-sm text-gray-500">Average Points</div>
                </div>
                
                <div class="bg-white rounded-lg border border-gray-200 p-4">
                    <div class="flex items-center justify-between mb-2">
                        <div class="w-10 h-10 bg-yellow-100 rounded-lg flex items-center justify-center">
                            <Activity class="w-5 h-5 text-yellow-600" />
                        </div>
                        <div class="flex items-center gap-1 text-red-600">
                            <TrendingDown class="w-4 h-4" />
                            <span class="text-sm font-medium">-3%</span>
                        </div>
                    </div>
                    <div class="text-2xl font-bold text-gray-900" x-text="participationRate + '%'"></div>
                    <div class="text-sm text-gray-500">Participation Rate</div>
                </div>
                
                <div class="bg-white rounded-lg border border-gray-200 p-4">
                    <div class="flex items-center justify-between mb-2">
                        <div class="w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center">
                            <Target class="w-5 h-5 text-purple-600" />
                        </div>
                        <div class="flex items-center gap-1 text-green-600">
                            <TrendingUp class="w-4 h-4" />
                            <span class="text-sm font-medium">+15%</span>
                        </div>
                    </div>
                    <div class="text-2xl font-bold text-gray-900" x-text="goalsAchieved"></div>
                    <div class="text-sm text-gray-500">Goals Achieved</div>
                </div>
            </div>

            <!-- Charts Section -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <!-- Points Over Time Chart -->
                <div class="bg-white rounded-lg border border-gray-200 p-6">
                    <div class="flex items-center justify-between mb-4">
                        <h2 class="text-lg font-semibold text-gray-900">Points Over Time</h2>
                        <div class="flex items-center gap-2">
                            <button @click="setChartType('line')" 
                                    class="p-2 rounded" 
                                    :class="chartType === 'line' ? 'bg-green-100 text-green-700' : 'text-gray-500 hover:text-gray-700'">
                                <TrendingUp class="w-4 h-4" />
                            </button>
                            <button @click="setChartType('bar')" 
                                    class="p-2 rounded" 
                                    :class="chartType === 'bar' ? 'bg-green-100 text-green-700' : 'text-gray-500 hover:text-gray-700'">
                                <BarChart3 class="w-4 h-4" />
                            </button>
                        </div>
                    </div>
                    
                    <div class="h-64 flex items-center justify-center bg-gray-50 rounded-lg">
                        <canvas x-ref="pointsChart" class="w-full h-full"></canvas>
                    </div>
                </div>

                <!-- Behavior Distribution -->
                <div class="bg-white rounded-lg border border-gray-200 p-6">
                    <div class="flex items-center justify-between mb-4">
                        <h2 class="text-lg font-semibold text-gray-900">Behavior Distribution</h2>
                        <PieChart class="w-5 h-5 text-gray-500" />
                    </div>
                    
                    <div class="h-64 flex items-center justify-center bg-gray-50 rounded-lg">
                        <canvas x-ref="behaviorChart" class="w-full h-full"></canvas>
                    </div>
                </div>
            </div>

            <!-- Top Performers -->
            <div class="bg-white rounded-lg border border-gray-200 p-6">
                <div class="flex items-center justify-between mb-4">
                    <h2 class="text-lg font-semibold text-gray-900">Top Performers</h2>
                    <select @change="updateTopPerformers($event.target.value)" 
                            class="px-3 py-1 border border-gray-300 rounded-lg text-sm">
                        <option value="points">By Points</option>
                        <option value="streak">By Streak</option>
                        <option value="improvement">Most Improved</option>
                    </select>
                </div>
                
                <div class="space-y-3">
                    <template x-for="(student, index) in topPerformers" :key="student.id">
                        <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 bg-gradient-to-br from-green-400 to-green-600 rounded-full flex items-center justify-center text-white font-bold text-sm">
                                    <span x-text="index + 1"></span>
                                </div>
                                <div class="w-10 h-10 bg-gray-200 rounded-full flex items-center justify-center text-lg">
                                    <span x-text="student.avatar"></span>
                                </div>
                                <div>
                                    <div class="font-medium text-gray-900" x-text="student.name"></div>
                                    <div class="text-sm text-gray-500">Level <span x-text="student.level"></span></div>
                                </div>
                            </div>
                            
                            <div class="text-right">
                                <div class="text-lg font-bold text-green-600" x-text="student.displayValue"></div>
                                <div class="text-sm text-gray-500" x-text="student.displayLabel"></div>
                            </div>
                        </div>
                    </template>
                </div>
            </div>

            <!-- Behavior Analysis -->
            <div class="bg-white rounded-lg border border-gray-200 p-6">
                <div class="flex items-center justify-between mb-4">
                    <h2 class="text-lg font-semibold text-gray-900">Behavior Analysis</h2>
                    <Filter class="w-5 h-5 text-gray-500" />
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <template x-for="behavior in behaviorAnalysis" :key="behavior.id">
                        <div class="p-4 border border-gray-200 rounded-lg">
                            <div class="flex items-center justify-between mb-2">
                                <div class="flex items-center gap-2">
                                    <span class="text-2xl" x-text="behavior.icon"></span>
                                    <div>
                                        <div class="font-medium text-gray-900" x-text="behavior.label"></div>
                                        <div class="text-sm text-gray-500"><span x-text="behavior.count"></span> uses</div>
                                    </div>
                                </div>
                                <div class="text-right">
                                    <div class="text-lg font-bold" :class="behavior.points > 0 ? 'text-green-600' : 'text-red-600'" 
                                         x-text="(behavior.points > 0 ? '+' : '') + behavior.totalPoints"></div>
                                    <div class="text-sm text-gray-500">total points</div>
                                </div>
                            </div>
                            
                            <div class="w-full bg-gray-200 rounded-full h-2">
                                <div class="h-2 rounded-full transition-all duration-300"
                                     :class="behavior.points > 0 ? 'bg-green-600' : 'bg-red-600'"
                                     :style="'width: ' + (Math.abs(behavior.totalPoints) / maxBehaviorPoints * 100) + '%'"></div>
                            </div>
                        </div>
                    </template>
                </div>
            </div>
        </main>
    </div>

    <script is:inline>
        function reportsPage() {
            return {
                loading: true,
                currentClass: null,
                students: [],
                dateRange: 'week',
                dateRangeLabel: 'This Week',
                chartType: 'line',
                topPerformers: [],
                behaviorAnalysis: [],
                totalStudents: 0,
                averagePoints: 0,
                participationRate: 0,
                goalsAchieved: 0,
                maxBehaviorPoints: 0,
                apiBaseUrl: 'http://localhost:3001/api',
                
                async init() {
                    const token = localStorage.getItem('authToken');
                    if (!token) {
                        window.location.href = '/login';
                        return;
                    }
                    
                    await this.loadData();
                    this.loading = false;
                    
                    // Initialize charts after data is loaded
                    this.$nextTick(() => {
                        this.initCharts();
                    });
                },
                
                async loadData() {
                    try {
                        const classId = new URLSearchParams(window.location.search).get('class');
                        if (!classId) return;
                        
                        const token = localStorage.getItem('authToken');
                        const response = await fetch(`${this.apiBaseUrl}/classes/${classId}`, {
                            headers: { 'Authorization': `Bearer ${token}` }
                        });
                        
                        if (response.ok) {
                            const data = await response.json();
                            this.currentClass = data;
                            this.students = data.students || [];
                            
                            this.calculateStats();
                            this.updateTopPerformers('points');
                            this.analyzeBehaviors();
                        }
                    } catch (error) {
                        console.error('Load data error:', error);
                    }
                },
                
                calculateStats() {
                    this.totalStudents = this.students.length;
                    this.averagePoints = this.students.length > 0 
                        ? Math.round(this.students.reduce((sum, s) => sum + s.points, 0) / this.students.length)
                        : 0;
                    this.participationRate = this.students.length > 0
                        ? Math.round((this.students.filter(s => s.points > 0).length / this.students.length) * 100)
                        : 0;
                    this.goalsAchieved = this.students.filter(s => s.level >= 3).length;
                },
                
                updateTopPerformers(type) {
                    let sorted = [...this.students];
                    
                    switch(type) {
                        case 'points':
                            sorted.sort((a, b) => b.points - a.points);
                            this.topPerformers = sorted.slice(0, 5).map(s => ({
                                ...s,
                                displayValue: s.points,
                                displayLabel: 'points'
                            }));
                            break;
                        case 'streak':
                            sorted.sort((a, b) => b.streak - a.streak);
                            this.topPerformers = sorted.slice(0, 5).map(s => ({
                                ...s,
                                displayValue: s.streak,
                                displayLabel: 'day streak'
                            }));
                            break;
                        case 'improvement':
                            // Mock improvement data
                            this.topPerformers = sorted.slice(0, 5).map((s, i) => ({
                                ...s,
                                displayValue: `+${Math.floor(Math.random() * 20) + 5}`,
                                displayLabel: 'this week'
                            }));
                            break;
                    }
                },
                
                analyzeBehaviors() {
                    // Mock behavior analysis data
                    this.behaviorAnalysis = [
                        { id: 1, label: 'Great Work', icon: '⭐', points: 2, count: 45, totalPoints: 90 },
                        { id: 2, label: 'Helped Friend', icon: '🤝', points: 1, count: 32, totalPoints: 32 },
                        { id: 3, label: 'On Task', icon: '📚', points: 1, count: 28, totalPoints: 28 },
                        { id: 4, label: 'Noisy', icon: '🔇', points: -1, count: 15, totalPoints: -15 },
                        { id: 5, label: 'Disruptive', icon: '⚠️', points: -2, count: 8, totalPoints: -16 }
                    ];
                    
                    this.maxBehaviorPoints = Math.max(...this.behaviorAnalysis.map(b => Math.abs(b.totalPoints)));
                },
                
                setDateRange(range) {
                    this.dateRange = range;
                    const labels = {
                        today: 'Today',
                        week: 'This Week',
                        month: 'This Month',
                        term: 'This Term'
                    };
                    this.dateRangeLabel = labels[range];
                    
                    // Reload data with new date range
                    this.loadData();
                },
                
                setChartType(type) {
                    this.chartType = type;
                    this.initCharts();
                },
                
                initCharts() {
                    this.initPointsChart();
                    this.initBehaviorChart();
                },
                
                initPointsChart() {
                    const canvas = this.$refs.pointsChart;
                    if (!canvas) return;
                    
                    const ctx = canvas.getContext('2d');
                    const width = canvas.offsetWidth;
                    const height = canvas.offsetHeight;
                    
                    // Clear canvas
                    ctx.clearRect(0, 0, width, height);
                    
                    // Mock data for demonstration
                    const data = [65, 78, 90, 81, 95, 89, 102];
                    const labels = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
                    
                    if (this.chartType === 'line') {
                        this.drawLineChart(ctx, data, labels, width, height);
                    } else {
                        this.drawBarChart(ctx, data, labels, width, height);
                    }
                },
                
                initBehaviorChart() {
                    const canvas = this.$refs.behaviorChart;
                    if (!canvas) return;
                    
                    const ctx = canvas.getContext('2d');
                    const width = canvas.offsetWidth;
                    const height = canvas.offsetHeight;
                    
                    // Clear canvas
                    ctx.clearRect(0, 0, width, height);
                    
                    // Mock pie chart data
                    const data = [35, 25, 20, 15, 5];
                    const colors = ['#10b981', '#3b82f6', '#f59e0b', '#ef4444', '#8b5cf6'];
                    
                    this.drawPieChart(ctx, data, colors, width, height);
                },
                
                drawLineChart(ctx, data, labels, width, height) {
                    const padding = 40;
                    const chartWidth = width - padding * 2;
                    const chartHeight = height - padding * 2;
                    
                    const maxValue = Math.max(...data);
                    const stepX = chartWidth / (data.length - 1);
                    
                    // Draw axes
                    ctx.strokeStyle = '#e5e7eb';
                    ctx.lineWidth = 1;
                    ctx.beginPath();
                    ctx.moveTo(padding, padding);
                    ctx.lineTo(padding, height - padding);
                    ctx.lineTo(width - padding, height - padding);
                    ctx.stroke();
                    
                    // Draw line
                    ctx.strokeStyle = '#10b981';
                    ctx.lineWidth = 2;
                    ctx.beginPath();
                    
                    data.forEach((value, index) => {
                        const x = padding + index * stepX;
                        const y = height - padding - (value / maxValue) * chartHeight;
                        
                        if (index === 0) {
                            ctx.moveTo(x, y);
                        } else {
                            ctx.lineTo(x, y);
                        }
                    });
                    
                    ctx.stroke();
                    
                    // Draw points
                    data.forEach((value, index) => {
                        const x = padding + index * stepX;
                        const y = height - padding - (value / maxValue) * chartHeight;
                        
                        ctx.fillStyle = '#10b981';
                        ctx.beginPath();
                        ctx.arc(x, y, 4, 0, Math.PI * 2);
                        ctx.fill();
                    });
                },
                
                drawBarChart(ctx, data, labels, width, height) {
                    const padding = 40;
                    const chartWidth = width - padding * 2;
                    const chartHeight = height - padding * 2;
                    
                    const maxValue = Math.max(...data);
                    const barWidth = chartWidth / data.length * 0.6;
                    const stepX = chartWidth / data.length;
                    
                    // Draw axes
                    ctx.strokeStyle = '#e5e7eb';
                    ctx.lineWidth = 1;
                    ctx.beginPath();
                    ctx.moveTo(padding, padding);
                    ctx.lineTo(padding, height - padding);
                    ctx.lineTo(width - padding, height - padding);
                    ctx.stroke();
                    
                    // Draw bars
                    data.forEach((value, index) => {
                        const x = padding + index * stepX + (stepX - barWidth) / 2;
                        const barHeight = (value / maxValue) * chartHeight;
                        const y = height - padding - barHeight;
                        
                        ctx.fillStyle = '#10b981';
                        ctx.fillRect(x, y, barWidth, barHeight);
                    });
                },
                
                drawPieChart(ctx, data, colors, width, height) {
                    const centerX = width / 2;
                    const centerY = height / 2;
                    const radius = Math.min(width, height) / 2 - 20;
                    
                    const total = data.reduce((sum, value) => sum + value, 0);
                    let currentAngle = -Math.PI / 2;
                    
                    data.forEach((value, index) => {
                        const sliceAngle = (value / total) * Math.PI * 2;
                        
                        // Draw slice
                        ctx.fillStyle = colors[index];
                        ctx.beginPath();
                        ctx.moveTo(centerX, centerY);
                        ctx.arc(centerX, centerY, radius, currentAngle, currentAngle + sliceAngle);
                        ctx.closePath();
                        ctx.fill();
                        
                        currentAngle += sliceAngle;
                    });
                },
                
                exportReport() {
                    alert('Export functionality coming soon! This will generate a PDF/Excel report.');
                }
            }
        }
    </script>
</MainLayout>
