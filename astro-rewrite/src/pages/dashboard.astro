---
import MainLayout from '../layouts/MainLayout.astro';
import { BookOpen, Users, Trophy, TrendingUp, Calendar, Bell } from 'lucide-react';
---

<MainLayout title="Teacher Dashboard - Klasiz.fun">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Header -->
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-gray-900">Welcome back, Ms. Johnson!</h1>
            <p class="text-gray-600 mt-2">Here's what's happening in your classes today.</p>
        </div>

        <!-- Stats Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <div class="bg-white p-6 rounded-lg border border-gray-200">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-600">Total Students</p>
                        <p class="text-2xl font-bold text-gray-900">156</p>
                    </div>
                    <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center">
                        <Users class="w-6 h-6 text-blue-600" />
                    </div>
                </div>
                <div class="mt-4 flex items-center text-sm">
                    <span class="text-green-600">↑ 12%</span>
                    <span class="text-gray-500 ml-2">from last month</span>
                </div>
            </div>

            <div class="bg-white p-6 rounded-lg border border-gray-200">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-600">Active Classes</p>
                        <p class="text-2xl font-bold text-gray-900">8</p>
                    </div>
                    <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center">
                        <BookOpen class="w-6 h-6 text-green-600" />
                    </div>
                </div>
                <div class="mt-4 flex items-center text-sm">
                    <span class="text-green-600">↑ 2</span>
                    <span class="text-gray-500 ml-2">new this week</span>
                </div>
            </div>

            <div class="bg-white p-6 rounded-lg border border-gray-200">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-600">Games Played</p>
                        <p class="text-2xl font-bold text-gray-900">1,247</p>
                    </div>
                    <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center">
                        <Trophy class="w-6 h-6 text-purple-600" />
                    </div>
                </div>
                <div class="mt-4 flex items-center text-sm">
                    <span class="text-green-600">↑ 23%</span>
                    <span class="text-gray-500 ml-2">engagement up</span>
                </div>
            </div>

            <div class="bg-white p-6 rounded-lg border border-gray-200">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-600">Avg. Score</p>
                        <p class="text-2xl font-bold text-gray-900">87%</p>
                    </div>
                    <div class="w-12 h-12 bg-yellow-100 rounded-lg flex items-center justify-center">
                        <TrendingUp class="w-6 h-6 text-yellow-600" />
                    </div>
                </div>
                <div class="mt-4 flex items-center text-sm">
                    <span class="text-green-600">↑ 5%</span>
                    <span class="text-gray-500 ml-2">improvement</span>
                </div>
            </div>
        </div>

        <!-- Recent Activity & Quick Actions -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Recent Activity -->
            <div class="lg:col-span-2">
                <div class="bg-white rounded-lg border border-gray-200">
                    <div class="p-6 border-b border-gray-200">
                        <h2 class="text-lg font-semibold text-gray-900">Recent Activity</h2>
                    </div>
                    <div class="p-6 space-y-4">
                        <div class="flex items-center space-x-4">
                            <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center">
                                <Trophy class="w-5 h-5 text-green-600" />
                            </div>
                            <div class="flex-1">
                                <p class="text-sm font-medium text-gray-900">Tornado Challenge completed</p>
                                <p class="text-sm text-gray-500">Class 3A - 25 students participated</p>
                            </div>
                            <span class="text-sm text-gray-500">2 hours ago</span>
                        </div>

                        <div class="flex items-center space-x-4">
                            <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center">
                                <Users class="w-5 h-5 text-blue-600" />
                            </div>
                            <div class="flex-1">
                                <p class="text-sm font-medium text-gray-900">New student joined</p>
                                <p class="text-sm text-gray-500">Emma Chen added to Class 4B</p>
                            </div>
                            <span class="text-sm text-gray-500">4 hours ago</span>
                        </div>

                        <div class="flex items-center space-x-4">
                            <div class="w-10 h-10 bg-purple-100 rounded-full flex items-center justify-center">
                                <BookOpen class="w-5 h-5 text-purple-600" />
                            </div>
                            <div class="flex-1">
                                <p class="text-sm font-medium text-gray-900">Lesson plan created</p>
                                <p class="text-sm text-gray-500">"Introduction to Fractions" for Class 5A</p>
                            </div>
                            <span class="text-sm text-gray-500">1 day ago</span>
                        </div>

                        <div class="flex items-center space-x-4">
                            <div class="w-10 h-10 bg-yellow-100 rounded-full flex items-center justify-center">
                                <TrendingUp class="w-5 h-5 text-yellow-600" />
                            </div>
                            <div class="flex-1">
                                <p class="text-sm font-medium text-gray-900">Progress report sent</p>
                                <p class="text-sm text-gray-500">Monthly reports sent to 45 parents</p>
                            </div>
                            <span class="text-sm text-gray-500">2 days ago</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div>
                <div class="bg-white rounded-lg border border-gray-200">
                    <div class="p-6 border-b border-gray-200">
                        <h2 class="text-lg font-semibold text-gray-900">Quick Actions</h2>
                    </div>
                    <div class="p-6 space-y-3">
                        <button class="w-full text-left px-4 py-3 bg-green-50 border border-green-200 rounded-lg hover:bg-green-100 transition-colors">
                            <div class="flex items-center">
                                <Trophy class="w-5 h-5 text-green-600 mr-3" />
                                <span class="text-sm font-medium text-gray-900">Start a Game</span>
                            </div>
                        </button>

                        <button class="w-full text-left px-4 py-3 bg-blue-50 border border-blue-200 rounded-lg hover:bg-blue-100 transition-colors">
                            <div class="flex items-center">
                                <Users class="w-5 h-5 text-blue-600 mr-3" />
                                <span class="text-sm font-medium text-gray-900">Add Students</span>
                            </div>
                        </button>

                        <button class="w-full text-left px-4 py-3 bg-purple-50 border border-purple-200 rounded-lg hover:bg-purple-100 transition-colors">
                            <div class="flex items-center">
                                <BookOpen class="w-5 h-5 text-purple-600 mr-3" />
                                <span class="text-sm font-medium text-gray-900">Create Lesson</span>
                            </div>
                        </button>

                        <button class="w-full text-left px-4 py-3 bg-yellow-50 border border-yellow-200 rounded-lg hover:bg-yellow-100 transition-colors">
                            <div class="flex items-center">
                                <Calendar class="w-5 h-5 text-yellow-600 mr-3" />
                                <span class="text-sm font-medium text-gray-900">Schedule Activity</span>
                            </div>
                        </button>

                        <button class="w-full text-left px-4 py-3 bg-red-50 border border-red-200 rounded-lg hover:bg-red-100 transition-colors">
                            <div class="flex items-center">
                                <Bell class="w-5 h-5 text-red-600 mr-3" />
                                <span class="text-sm font-medium text-gray-900">Send Notification</span>
                            </div>
                        </button>
                    </div>
                </div>

                <!-- Upcoming Events -->
                <div class="bg-white rounded-lg border border-gray-200 mt-6">
                    <div class="p-6 border-b border-gray-200">
                        <h2 class="text-lg font-semibold text-gray-900">Upcoming Events</h2>
                    </div>
                    <div class="p-6 space-y-3">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-sm font-medium text-gray-900">Math Quiz</p>
                                <p class="text-sm text-gray-500">Class 4A</p>
                            </div>
                            <span class="text-sm text-gray-500">Tomorrow</span>
                        </div>

                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-sm font-medium text-gray-900">Parent Meeting</p>
                                <p class="text-sm text-gray-500">All Classes</p>
                            </div>
                            <span class="text-sm text-gray-500">Friday</span>
                        </div>

                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-sm font-medium text-gray-900">Spelling Bee</p>
                                <p class="text-sm text-gray-500">Grade 5</p>
                            </div>
                            <span class="text-sm text-gray-500">Next Week</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</MainLayout>
