---
import MainLayout from '../layouts/MainLayout.astro';
import AppLayout from '../layouts/AppLayout.astro';
import { BookOpen, Users, Trophy, Plus, Search, Filter, MoreVertical } from 'lucide-react';
---

<AppLayout title="Classes - Klasiz.fun">
    <div x-data="classesDashboard()" x-init="initClasses()" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Header -->
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-8">
            <div>
                <h1 class="text-3xl font-bold text-gray-900">My Classes</h1>
                <p class="text-gray-600 mt-2">Manage your classes and track student progress</p>
            </div>
            <button @click="createClass()" class="mt-4 sm:mt-0 bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 transition-colors flex items-center">
                <Plus class="w-5 h-5 mr-2" />
                Create New Class
            </button>
        </div>

        <!-- Search and Filter -->
        <div class="flex flex-col sm:flex-row gap-4 mb-8">
            <div class="flex-1 relative">
                <Search class="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400 w-5 h-5" />
                <input 
                    type="text" 
                    placeholder="Search classes..."
                    x-model="searchQuery"
                    class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent"
                >
            </div>
        </div>

        <!-- Classes Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <template x-for="classItem in filteredClasses" :key="classItem.id">
                <div class="bg-white rounded-lg border border-gray-200 hover:shadow-lg transition-shadow">
                    <!-- Class Header -->
                    <div class="p-6 border-b border-gray-200">
                        <div class="flex items-start justify-between">
                            <div class="flex-1">
                                <h3 class="text-lg font-semibold text-gray-900" x-text="classItem.name"></h3>
                                <p class="text-sm text-gray-500" x-text="classItem.grade"></p>
                            </div>
                            <button @click="deleteClass(classItem.id)" class="text-red-400 hover:text-red-600">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                            </button>
                        </div>
                    </div>

                    <!-- Class Stats -->
                    <div class="p-6">
                        <div class="grid grid-cols-2 gap-4 mb-4">
                            <div class="text-center">
                                <div class="text-2xl font-bold text-gray-900" x-text="getStudentCount(classItem.id)"></div>
                                <div class="text-xs text-gray-500">Students</div>
                            </div>
                            <div class="text-center">
                                <div class="text-2xl font-bold text-green-600" x-text="getClassPoints(classItem.id)"></div>
                                <div class="text-xs text-gray-500">Total Points</div>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="flex gap-2">
                            <a :href="`/class-dashboard?class=${classItem.id}`" class="flex-1 bg-green-600 text-white px-3 py-2 rounded-lg hover:bg-green-700 transition-colors text-sm text-center">
                                View Class
                            </a>
                            <a :href="`/game-center?class=${classItem.id}`" class="flex-1 border border-gray-300 text-gray-700 px-3 py-2 rounded-lg hover:bg-gray-50 transition-colors text-sm text-center">
                                Start Game
                            </a>
                        </div>
                    </div>
                </div>
            </template>
        </div>

        <!-- Empty State -->
        <div x-show="filteredClasses.length === 0" class="text-center py-12">
            <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <BookOpen class="w-8 h-8 text-gray-400" />
            </div>
            <h3 class="text-lg font-medium text-gray-900 mb-2">No classes found</h3>
            <p class="text-gray-500 mb-4">Get started by creating your first class</p>
            <button @click="createClass()" class="bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 transition-colors">
                Create New Class
            </button>
        </div>
    </div>

    <script>
        import { store } from '../lib/appState.js';
        
        function classesDashboard() {
            return {
                searchQuery: '',
                classes: [],
                
                initClasses() {
                    this.classes = store.getState().classes;
                    window.addEventListener('state-updated', (e) => {
                        this.classes = e.detail.classes;
                    });
                },
                
                get filteredClasses() {
                    if (!this.searchQuery) return this.classes;
                    
                    const query = this.searchQuery.toLowerCase();
                    return this.classes.filter(cls => 
                        cls.name.toLowerCase().includes(query) ||
                        cls.grade.toLowerCase().includes(query)
                    );
                },
                
                getStudentCount(classId) {
                    return store.getStudentsByClass(classId).length;
                },
                
                getClassPoints(classId) {
                    const students = store.getStudentsByClass(classId);
                    return students.reduce((sum, s) => sum + s.points, 0);
                },
                
                createClass() {
                    const name = prompt('Enter class name (e.g., Math Grade 3):');
                    if (!name) return;
                    
                    const grade = prompt('Enter grade level (e.g., Grade 3):') || 'Grade 3';
                    
                    store.addClass(name, grade);
                    this.classes = store.getState().classes;
                },
                
                deleteClass(classId) {
                    if (confirm('Are you sure? This will delete all students in this class.')) {
                        store.deleteClass(classId);
                        this.classes = store.getState().classes;
                    }
                }
            }
        }
    </script>
</AppLayout>
