---
import MainLayout from '../layouts/MainLayout.astro';
import { HelpCircle, ChevronDown, ChevronUp, Mail, ArrowRight, BookOpen, Users, Settings, Award, Gamepad2, Calendar } from 'lucide-react';
---

<MainLayout title="FAQ - Klasiz.fun" description="Frequently asked questions about classroom management, assignments, parent access, and platform features.">
    <div class="min-h-screen bg-gray-50 dark:bg-gray-900" x-data="{ isDark: false, expandedIndex: null }" x-init="isDark = localStorage.getItem('theme') === 'dark'">
        <!-- Navbar -->
        <nav class="fixed top-0 left-0 right-0 z-50 bg-white/95 dark:bg-gray-900/95 backdrop-blur-xl border-b border-gray-200 dark:border-gray-800">
            <div class="px-4 sm:px-6 lg:px-8 flex justify-between items-center h-16">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-blue-600 rounded-lg flex items-center justify-center">
                        <HelpCircle class="w-5 h-5 text-white" />
                    </div>
                    <span class="text-xl font-bold text-gray-900 dark:text-white">FAQ</span>
                </div>
                <a href="/" class="px-4 py-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 font-medium flex items-center gap-2 transition-all">
                    <ArrowRight class="w-4 h-4" />
                    <span class="hidden sm:inline">Back to Home</span>
                    <span class="sm:hidden">Back</span>
                </a>
            </div>
        </nav>

        <!-- Hero Section -->
        <section class="pt-24 pb-12 px-4 sm:px-6 lg:px-8 text-center bg-gradient-to-br from-blue-50 to-purple-50 dark:from-gray-900 dark:to-blue-900/20">
            <div class="max-w-3xl mx-auto">
                <div class="w-20 h-20 bg-gradient-to-br from-blue-500 to-blue-600 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-xl shadow-blue-500/30">
                    <HelpCircle class="w-10 h-10 text-white" />
                </div>
                <h1 class="text-4xl sm:text-5xl font-black mb-4 text-gray-900 dark:text-white">
                    Frequently Asked Questions
                </h1>
                <p class="text-lg text-gray-600 dark:text-gray-300 max-w-2xl mx-auto leading-relaxed">
                    Find answers to common questions about Klasiz.fun features, usage, and policies.
                </p>
            </div>
        </section>

        <!-- FAQ Content -->
        <section class="py-16 px-4 sm:px-6 lg:px-8">
            <div class="max-w-4xl mx-auto space-y-12">
                
                <!-- Getting Started -->
                <div>
                    <h2 class="text-2xl font-bold mb-6 text-gray-900 dark:text-white flex items-center gap-3">
                        <BookOpen class="w-6 h-6 text-blue-500" />
                        Getting Started
                    </h2>
                    <div class="space-y-4">
                        <!-- Q1 -->
                        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
                            <button @click="expandedIndex = expandedIndex === 1 ? null : 1" class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                                <span class="font-semibold text-gray-900 dark:text-white">What is Klasiz.fun?</span>
                                <ChevronDown class="w-5 h-5 text-gray-500 transition-transform" :class="expandedIndex === 1 ? 'rotate-180' : ''" />
                            </button>
                            <div x-show="expandedIndex === 1" x-collapse class="px-6 pb-4 text-gray-700 dark:text-gray-300">
                                Klasiz.fun is a modern classroom management platform designed to help teachers run calmer, more joyful classes. It combines behavior tracking, points and rewards, live dashboards, lesson planning tools, parent communication, and playful games—all in one place.
                            </div>
                        </div>
                        
                        <!-- Q2 -->
                        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
                            <button @click="expandedIndex = expandedIndex === 2 ? null : 2" class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                                <span class="font-semibold text-gray-900 dark:text-white">Is Klasiz.fun free to use?</span>
                                <ChevronDown class="w-5 h-5 text-gray-500 transition-transform" :class="expandedIndex === 2 ? 'rotate-180' : ''" />
                            </button>
                            <div x-show="expandedIndex === 2" x-collapse class="px-6 pb-4 text-gray-700 dark:text-gray-300">
                                Yes! Klasiz.fun is completely free for teachers to create classes, add students, track behavior, and use all core features. We believe in making classroom management accessible to every teacher.
                            </div>
                        </div>
                        
                        <!-- Q3 -->
                        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
                            <button @click="expandedIndex = expandedIndex === 3 ? null : 3" class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                                <span class="font-semibold text-gray-900 dark:text-white">How do I create a class?</span>
                                <ChevronDown class="w-5 h-5 text-gray-500 transition-transform" :class="expandedIndex === 3 ? 'rotate-180' : ''" />
                            </button>
                            <div x-show="expandedIndex === 3" x-collapse class="px-6 pb-4 text-gray-700 dark:text-gray-300">
                                After signing up, simply click "Create My Class" in your teacher portal. Give your class a name, optionally upload a class photo, and you're ready to start adding students and managing behavior.
                            </div>
                        </div>
                        
                        <!-- Q4 -->
                        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
                            <button @click="expandedIndex = expandedIndex === 4 ? null : 4" class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                                <span class="font-semibold text-gray-900 dark:text-white">How do I add students to my class?</span>
                                <ChevronDown class="w-5 h-5 text-gray-500 transition-transform" :class="expandedIndex === 4 ? 'rotate-180' : ''" />
                            </button>
                            <div x-show="expandedIndex === 4" x-collapse class="px-6 pb-4 text-gray-700 dark:text-gray-300">
                                In your class dashboard, click "Manage Students" and then "Add Student." Enter the student's name, select their gender, and optionally upload a photo. You can add as many students as you need.
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Features & Usage -->
                <div>
                    <h2 class="text-2xl font-bold mb-6 text-gray-900 dark:text-white flex items-center gap-3">
                        <Settings class="w-6 h-6 text-purple-500" />
                        Features & Usage
                    </h2>
                    <div class="space-y-4">
                        <!-- Q5 -->
                        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
                            <button @click="expandedIndex = expandedIndex === 5 ? null : 5" class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                                <span class="font-semibold text-gray-900 dark:text-white">How does the points system work?</span>
                                <ChevronDown class="w-5 h-5 text-gray-500 transition-transform" :class="expandedIndex === 5 ? 'rotate-180' : ''" />
                            </button>
                            <div x-show="expandedIndex === 5" x-collapse class="px-6 pb-4 text-gray-700 dark:text-gray-300">
                                Teachers can award points to students for positive behaviors (WOW cards) or deduct points for behaviors that need improvement (NO-NO cards). You can customize the point values and behavior labels to match your classroom needs.
                            </div>
                        </div>
                        
                        <!-- Q6 -->
                        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
                            <button @click="expandedIndex = expandedIndex === 6 ? null : 6" class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                                <span class="font-semibold text-gray-900 dark:text-white">What is the Progress Meter?</span>
                                <ChevronDown class="w-5 h-5 text-gray-500 transition-transform" :class="expandedIndex === 6 ? 'rotate-180' : ''" />
                            </button>
                            <div x-show="expandedIndex === 6" x-collapse class="px-6 pb-4 text-gray-700 dark:text-gray-300">
                                The Progress Meter is a collaborative goal tracker that motivates your entire class. As students earn points, the meter fills up. When the class reaches milestones, you can celebrate together and reset for the next goal.
                            </div>
                        </div>
                        
                        <!-- Q7 -->
                        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
                            <button @click="expandedIndex = expandedIndex === 7 ? null : 7" class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                                <span class="font-semibold text-gray-900 dark:text-white">How does Lucky Draw work?</span>
                                <ChevronDown class="w-5 h-5 text-gray-500 transition-transform" :class="expandedIndex === 7 ? 'rotate-180' : ''" />
                            </button>
                            <div x-show="expandedIndex === 7" x-collapse class="px-6 pb-4 text-gray-700 dark:text-gray-300">
                                Lucky Draw is a gamification feature that randomly selects students for rewards. You can set how many students to select, and the system will randomly pick winners—keeping every lesson exciting and fair.
                            </div>
                        </div>
                        
                        <!-- Q8 -->
                        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
                            <button @click="expandedIndex = expandedIndex === 8 ? null : 8" class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                                <span class="font-semibold text-gray-900 dark:text-white">Can I create assignments in Klasiz.fun?</span>
                                <ChevronDown class="w-5 h-5 text-gray-500 transition-transform" :class="expandedIndex === 8 ? 'rotate-180' : ''" />
                            </button>
                            <div x-show="expandedIndex === 8" x-collapse class="px-6 pb-4 text-gray-700 dark:text-gray-300">
                                Yes! The Assignments Studio lets you create digital worksheets with multiple question types, assign them to specific students or the whole class, and grade submissions with instant feedback.
                            </div>
                        </div>
                        
                        <!-- Q9 -->
                        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
                            <button @click="expandedIndex = expandedIndex === 9 ? null : 9" class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                                <span class="font-semibold text-gray-900 dark:text-white">What is the Focus Timer?</span>
                                <ChevronDown class="w-5 h-5 text-gray-500 transition-transform" :class="expandedIndex === 9 ? 'rotate-180' : ''" />
                            </button>
                            <div x-show="expandedIndex === 9" x-collapse class="px-6 pb-4 text-gray-700 dark:text-gray-300">
                                The Focus Timer is a built-in timer for activities and tests. It provides visual cues so the whole class can see how much time remains, helping students stay focused and manage their time better.
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Parents & Students -->
                <div>
                    <h2 class="text-2xl font-bold mb-6 text-gray-900 dark:text-white flex items-center gap-3">
                        <Users class="w-6 h-6 text-green-500" />
                        Parents & Students
                    </h2>
                    <div class="space-y-4">
                        <!-- Q10 -->
                        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
                            <button @click="expandedIndex = expandedIndex === 10 ? null : 10" class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                                <span class="font-semibold text-gray-900 dark:text-white">How do parents access their child's progress?</span>
                                <ChevronDown class="w-5 h-5 text-gray-500 transition-transform" :class="expandedIndex === 10 ? 'rotate-180' : ''" />
                            </button>
                            <div x-show="expandedIndex === 10" x-collapse class="px-6 pb-4 text-gray-700 dark:text-gray-300">
                                Parents can log in with a special parent code to view their child's progress, behavior history, and any messages from the teacher. This keeps families informed and engaged.
                            </div>
                        </div>
                        
                        <!-- Q11 -->
                        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
                            <button @click="expandedIndex = expandedIndex === 11 ? null : 11" class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                                <span class="font-semibold text-gray-900 dark:text-white">How do students join my class?</span>
                                <ChevronDown class="w-5 h-5 text-gray-500 transition-transform" :class="expandedIndex === 11 ? 'rotate-180' : ''" />
                            </button>
                            <div x-show="expandedIndex === 11" x-collapse class="px-6 pb-4 text-gray-700 dark:text-gray-300">
                                Students can join your class by entering a 5-digit access code that you provide. They can then see their own progress, points, and any assignments you've created for them.
                            </div>
                        </div>
                        
                        <!-- Q12 -->
                        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
                            <button @click="expandedIndex = expandedIndex === 12 ? null : 12" class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                                <span class="font-semibold text-gray-900 dark:text-white">Can students see their points and progress?</span>
                                <ChevronDown class="w-5 h-5 text-gray-500 transition-transform" :class="expandedIndex === 12 ? 'rotate-180' : ''" />
                            </button>
                            <div x-show="expandedIndex === 12" x-collapse class="px-6 pb-4 text-gray-700 dark:text-gray-300">
                                Yes! Students have their own dashboard where they can see their current points, behavior history, and progress toward class goals. This transparency helps motivate them.
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Security & Privacy -->
                <div>
                    <h2 class="text-2xl font-bold mb-6 text-gray-900 dark:text-white flex items-center gap-3">
                        <Award class="w-6 h-6 text-orange-500" />
                        Security & Privacy
                    </h2>
                    <div class="space-y-4">
                        <!-- Q13 -->
                        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
                            <button @click="expandedIndex = expandedIndex === 13 ? null : 13" class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                                <span class="font-semibold text-gray-900 dark:text-white">Is my student data safe?</span>
                                <ChevronDown class="w-5 h-5 text-gray-500 transition-transform" :class="expandedIndex === 13 ? 'rotate-180' : ''" />
                            </button>
                            <div x-show="expandedIndex === 13" x-collapse class="px-6 pb-4 text-gray-700 dark:text-gray-300">
                                Absolutely. Klasiz.fun uses industry-standard encryption (HTTPS) to protect all data in transit. Student data is owned and controlled by the teacher or school account that created the class. We never sell student data or use it for advertising.
                            </div>
                        </div>
                        
                        <!-- Q14 -->
                        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
                            <button @click="expandedIndex = expandedIndex === 14 ? null : 14" class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                                <span class="font-semibold text-gray-900 dark:text-white">Is Klasiz.fun COPPA compliant?</span>
                                <ChevronDown class="w-5 h-5 text-gray-500 transition-transform" :class="expandedIndex === 14 ? 'rotate-180' : ''" />
                            </button>
                            <div x-show="expandedIndex === 14" x-collapse class="px-6 pb-4 text-gray-700 dark:text-gray-300">
                                Yes, Klasiz.fun is designed with student privacy in mind and complies with COPPA (Children's Online Privacy Protection Act) and other relevant privacy regulations. See our Privacy Policy for more details.
                            </div>
                        </div>
                        
                        <!-- Q15 -->
                        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
                            <button @click="expandedIndex = expandedIndex === 15 ? null : 15" class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                                <span class="font-semibold text-gray-900 dark:text-white">Can I delete my class and all student data?</span>
                                <ChevronDown class="w-5 h-5 text-gray-500 transition-transform" :class="expandedIndex === 15 ? 'rotate-180' : ''" />
                            </button>
                            <div x-show="expandedIndex === 15" x-collapse class="px-6 pb-4 text-gray-700 dark:text-gray-300">
                                Yes, you can delete your class and all associated student data at any time from your class settings. This action is permanent and cannot be undone.
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Games & Activities -->
                <div>
                    <h2 class="text-2xl font-bold mb-6 text-gray-900 dark:text-white flex items-center gap-3">
                        <Gamepad2 class="w-6 h-6 text-pink-500" />
                        Games & Activities
                    </h2>
                    <div class="space-y-4">
                        <!-- Q16 -->
                        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
                            <button @click="expandedIndex = expandedIndex === 16 ? null : 16" class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                                <span class="font-semibold text-gray-900 dark:text-white">What games are available?</span>
                                <ChevronDown class="w-5 h-5 text-gray-500 transition-transform" :class="expandedIndex === 16 ? 'rotate-180' : ''" />
                            </button>
                            <div x-show="expandedIndex === 16" x-collapse class="px-6 pb-4 text-gray-700 dark:text-gray-300">
                                Klasiz.fun offers several educational games including Tornado Challenge, Face Off, Memory Match, Quiz Bowl, Moto Race, Horse Race, and Spell the Word. More games are added regularly!
                            </div>
                        </div>
                        
                        <!-- Q17 -->
                        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
                            <button @click="expandedIndex = expandedIndex === 17 ? null : 17" class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                                <span class="font-semibold text-gray-900 dark:text-white">Can I customize the games?</span>
                                <ChevronDown class="w-5 h-5 text-gray-500 transition-transform" :class="expandedIndex === 17 ? 'rotate-180' : ''" />
                            </button>
                            <div x-show="expandedIndex === 17" x-collapse class="px-6 pb-4 text-gray-700 dark:text-gray-300">
                                Yes! Each game has customization options. You can adjust difficulty, add your own content (words, images, questions), set time limits, and choose the number of players.
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </section>

        <!-- Contact CTA -->
        <section class="py-16 px-4 sm:px-6 lg:px-8 bg-gradient-to-br from-green-500 to-green-600">
            <div class="max-w-4xl mx-auto text-center">
                <h2 class="text-3xl font-bold text-white mb-4">Still Have Questions?</h2>
                <p class="text-green-100 mb-8 max-w-2xl mx-auto">Our support team is here to help. Reach out and we'll get back to you as soon as possible.</p>
                <a href="mailto:support@klasiz.fun" class="inline-flex items-center gap-2 bg-white text-green-600 px-8 py-4 rounded-xl font-bold hover:bg-green-50 transition-all shadow-xl">
                    <Mail class="w-5 h-5" />
                    Contact Support
                </a>
            </div>
        </section>

        <!-- Footer -->
        <footer class="bg-white dark:bg-gray-900 border-t border-gray-200 dark:border-gray-800 py-12 px-4 sm:px-6 lg:px-8">
            <div class="max-w-6xl mx-auto text-center text-sm text-gray-600 dark:text-gray-400">
                © 2024 Klasiz.fun. All rights reserved.
            </div>
        </footer>
    </div>
</MainLayout>
