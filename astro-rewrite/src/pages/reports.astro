---
import MainLayout from '../layouts/MainLayout.astro';
import { Download, Printer, Plus, X, MoreVertical } from 'lucide-react';
---

<MainLayout title="Student Reports - Klasiz.fun" description="View and generate student progress reports">
    <div x-data="reportsPage()" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Header -->
        <div class="mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
                <h1 class="text-2xl font-bold text-gray-900 dark:text-white" x-text="pageTitle"></h1>
                <p class="text-gray-600 dark:text-gray-400 mt-1">Track student progress and generate reports</p>
            </div>
            <div class="flex items-center gap-2">
                <button @click="showFilters = !showFilters" class="px-4 py-2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/></svg>
                    Filters
                </button>
                <button @click="exportPDF" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 flex items-center gap-2">
                    <Download class="w-4 h-4" /> Export PDF
                </button>
            </div>
        </div>

        <!-- Filters Panel -->
        <div x-show="showFilters" x-transition class="mb-6 p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <!-- Time Range -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Time Range</label>
                    <select x-model="timeRange" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white">
                        <option value="week">This Week</option>
                        <option value="month">This Month</option>
                        <option value="year">This Year</option>
                        <option value="custom">Custom Range</option>
                    </select>
                </div>
                
                <!-- Student Selection -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Students</label>
                    <select x-model="selectedStudent" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white">
                        <option value="all">All Students</option>
                        <template x-for="student in students" :key="student.id">
                            <option :value="student.id" x-text="student.name"></option>
                        </template>
                    </select>
                </div>
                
                <!-- Report Type -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Report Type</label>
                    <select x-model="reportType" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white">
                        <option value="behavior">Behavior Report</option>
                        <option value="points">Points Summary</option>
                        <option value="attendance">Attendance</option>
                        <option value="comprehensive">Comprehensive</option>
                    </select>
                </div>
            </div>
            
            <!-- Custom Date Range -->
            <div x-show="timeRange === 'custom'" class="mt-4 grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Start Date</label>
                    <input type="date" x-model="startDate" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">End Date</label>
                    <input type="date" x-model="endDate" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white">
                </div>
            </div>
        </div>

        <!-- Main Content Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Behavior Chart -->
            <div class="lg:col-span-2 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-6">
                <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Behavior Distribution</h2>
                <div class="h-64 flex items-center justify-center bg-gray-50 dark:bg-gray-900 rounded-lg">
                    <div x-show="loading" class="text-center">
                        <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-green-600 mx-auto"></div>
                        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Loading chart...</p>
                    </div>
                    <div x-show="!loading && hasData" class="w-full h-full flex items-center justify-center">
                        <!-- Simple bar chart visualization -->
                        <div class="flex items-end justify-center gap-4 h-48">
                            <div class="flex flex-col items-center">
                                <div class="w-16 bg-green-500 rounded-t-lg transition-all duration-500" :style="`height: ${positivePercent}%`"></div>
                                <span class="mt-2 text-xs text-gray-600 dark:text-gray-400">Positive</span>
                                <span class="text-sm font-semibold text-gray-900 dark:text-white" x-text="positiveCount"></span>
                            </div>
                            <div class="flex flex-col items-center">
                                <div class="w-16 bg-red-500 rounded-t-lg transition-all duration-500" :style="`height: ${negativePercent}%`"></div>
                                <span class="mt-2 text-xs text-gray-600 dark:text-gray-400">Needs Work</span>
                                <span class="text-sm font-semibold text-gray-900 dark:text-white" x-text="negativeCount"></span>
                            </div>
                        </div>
                    </div>
                    <div x-show="!loading && !hasData" class="text-center text-gray-500">
                        <p>No data available for this selection</p>
                    </div>
                </div>
            </div>

            <!-- Stats Summary -->
            <div class="space-y-4">
                <!-- Total Points Card -->
                <div class="bg-gradient-to-br from-green-500 to-green-600 rounded-lg p-6 text-white">
                    <h3 class="text-sm font-medium opacity-90">Total Points</h3>
                    <p class="text-4xl font-bold mt-2" x-text="totalPoints"></p>
                    <div class="mt-4 flex items-center gap-2 text-sm opacity-90">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                        <span x-text="pointsChange > 0 ? '+' + pointsChange : pointsChange + '% from last period'"></span>
                    </div>
                </div>

                <!-- Ratio Card -->
                <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-6">
                    <h3 class="text-sm font-medium text-gray-600 dark:text-gray-400">Positive:Negative Ratio</h3>
                    <p class="text-3xl font-bold text-gray-900 dark:text-white mt-2" x-text="ratio"></p>
                    <div class="mt-3 w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2">
                        <div class="bg-green-500 h-2 rounded-full transition-all duration-500" :style="`width: ${ratioPercent}%`"></div>
                    </div>
                </div>

                <!-- Quick Actions -->
                <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-4">
                    <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-3">Quick Actions</h3>
                    <div class="space-y-2">
                        <button @click="printReport" class="w-full px-3 py-2 text-left text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 rounded flex items-center gap-2">
                            <Printer class="w-4 h-4" /> Print Report
                        </button>
                        <button @click="emailToParents" class="w-full px-3 py-2 text-left text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 rounded flex items-center gap-2">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                            Email to Parents
                        </button>
                        <button @click="addComment" class="w-full px-3 py-2 text-left text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 rounded flex items-center gap-2">
                            <Plus class="w-4 h-4" /> Add Teacher Comment
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Detailed Behavior Breakdown -->
        <div class="mt-6 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700">
            <div class="p-6 border-b border-gray-200 dark:border-gray-700">
                <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Detailed Breakdown</h2>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gray-50 dark:bg-gray-900">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Category</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Positive</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Needs Work</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Net</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Trend</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                        <template x-for="category in behaviorCategories" :key="category.name">
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-white" x-text="category.name"></td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-green-600" x-text=" '+' + category.positive"></td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-red-600" x-text="category.negative"></td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold" :class="category.net >= 0 ? 'text-green-600' : 'text-red-600'" x-text="category.net >= 0 ? '+' + category.net : category.net"></td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center gap-1" :class="category.trend === 'up' ? 'text-green-600' : category.trend === 'down' ? 'text-red-600' : 'text-gray-400'">
                                        <svg x-show="category.trend === 'up'" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                                        <svg x-show="category.trend === 'down'" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6"/></svg>
                                        <svg x-show="category.trend === 'stable'" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14"/></svg>
                                    </div>
                                </td>
                            </tr>
                        </template>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Teacher Feedback Section -->
        <div class="mt-6 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-6">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Teacher Feedback</h2>
            <textarea 
                x-model="teacherFeedback"
                placeholder="Add your observations and feedback about this student's progress..."
                class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white min-h-[120px] focus:ring-2 focus:ring-green-500 focus:border-transparent"
            ></textarea>
            <div class="mt-4 flex justify-end gap-2">
                <button @click="saveFeedback" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700">Save Feedback</button>
            </div>
        </div>

        <!-- Loading Overlay -->
        <div x-show="loading" class="fixed inset-0 bg-black/50 flex items-center justify-center z-50" style="display: none;">
            <div class="bg-white dark:bg-gray-800 rounded-lg p-6 max-w-sm mx-4">
                <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-green-600 mx-auto"></div>
                <p class="mt-4 text-center text-gray-600 dark:text-gray-400">Generating report...</p>
            </div>
        </div>
    </div>

    <script is:inline>
        function reportsPage() {
            return {
                showFilters: false,
                timeRange: 'month',
                selectedStudent: 'all',
                reportType: 'behavior',
                startDate: '',
                endDate: '',
                loading: false,
                pageTitle: 'Class Reports',
                
                // Sample data
                students: [
                    { id: 1, name: 'Alice Johnson' },
                    { id: 2, name: 'Bob Smith' },
                    { id: 3, name: 'Carol Williams' },
                    { id: 4, name: 'David Brown' }
                ],
                
                behaviorCategories: [
                    { name: 'Participation', positive: 25, negative: -3, net: 22, trend: 'up' },
                    { name: 'Homework', positive: 18, negative: -5, net: 13, trend: 'stable' },
                    { name: 'Behavior', positive: 30, negative: -2, net: 28, trend: 'up' },
                    { name: 'Collaboration', positive: 20, negative: -4, net: 16, trend: 'down' }
                ],
                
                totalPoints: 79,
                pointsChange: 15,
                positiveCount: 93,
                negativeCount: -14,
                ratio: '6.6:1',
                
                teacherFeedback: '',
                
                get hasData() {
                    return this.positiveCount > 0 || Math.abs(this.negativeCount) > 0;
                },
                
                get positivePercent() {
                    const max = Math.max(this.positiveCount, Math.abs(this.negativeCount));
                    return max > 0 ? (this.positiveCount / max) * 100 : 0;
                },
                
                get negativePercent() {
                    const max = Math.max(this.positiveCount, Math.abs(this.negativeCount));
                    return max > 0 ? (Math.abs(this.negativeCount) / max) * 100 : 0;
                },
                
                get ratioPercent() {
                    const parts = this.ratio.split(':');
                    if (parts.length === 2) {
                        const positive = parseFloat(parts[0]);
                        const total = positive + 1;
                        return (positive / total) * 100;
                    }
                    return 50;
                },
                
                init() {
                    // Set default dates for custom range
                    const today = new Date();
                    const weekAgo = new Date(today.getTime() - 7 * 24 * 60 * 60 * 1000);
                    this.endDate = today.toISOString().split('T')[0];
                    this.startDate = weekAgo.toISOString().split('T')[0];
                    
                    // Load saved preferences
                    const savedRange = localStorage.getItem('reports_time_range');
                    if (savedRange) this.timeRange = savedRange;
                    
                    // Watch for changes and save preferences
                    this.$watch('timeRange', value => {
                        localStorage.setItem('reports_time_range', value);
                    });
                },
                
                exportPDF() {
                    this.loading = true;
                    setTimeout(() => {
                        this.loading = false;
                        alert('PDF report downloaded!');
                    }, 1500);
                },
                
                printReport() {
                    window.print();
                },
                
                emailToParents() {
                    alert('Report will be emailed to parents');
                },
                
                addComment() {
                    const comment = prompt('Enter your comment:');
                    if (comment) {
                        this.teacherFeedback = comment;
                    }
                },
                
                saveFeedback() {
                    localStorage.setItem('teacher_feedback_' + this.selectedStudent, this.teacherFeedback);
                    alert('Feedback saved successfully!');
                }
            }
        }
    </script>
</MainLayout>
