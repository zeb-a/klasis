                init() {
                    setTimeout(() => {
                        if (this.$refs.scrollContainer && this.$refs.scrollContainer.children) {
                            const observer = new IntersectionObserver((entries) => {
                                entries.forEach(entry => {
                                    if (entry.isIntersecting) {
                                        const slides = Array.from(this.$refs.scrollContainer.children);
                                        for (let i = 0; i < slides.length; i++) {
                                            if (slides[i] === entry.target) {
                                                this.activeSlide = i;
                                                break;
                                            }
                                        }
                                    }
                                });
                            }, { threshold: 0.5, root: this.$refs.scrollContainer });
                            
                            Array.from(this.$refs.scrollContainer.children).forEach(slide => observer.observe(slide));
                        }
                    }, 100);
                },
                
                showModal(mode) {
                    this.modalMode = mode;
                },
                
                scrollToSlide(index) {
                    if (this.$refs.scrollContainer && this.$refs.scrollContainer.children && this.$refs.scrollContainer.children[index]) {
                        this.$refs.scrollContainer.children[index].scrollIntoView({ behavior: 'smooth' });
                    }
                },
                
