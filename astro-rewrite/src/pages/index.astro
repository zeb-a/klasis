---
import MainLayout from '../layouts/MainLayout.astro';
import { ArrowRight, LogIn, Sparkles, Star, GraduationCap, Heart, BookOpen, Dices, Quote, Moon, Sun, MoreVertical, Layout, Trophy, Settings, QrCode, X, GaugeCircle, BarChart3, Users, MessageSquare } from 'lucide-react';
---

<!-- Alpine.js CDN -->
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

<MainLayout title="Klasiz.fun - Modern Classroom Management" description="Transform your classroom with gamification, real-time tracking, and parent engagement.">
    <div x-data="landingPage()" class="relative">
        <!-- FIXED NAVBAR -->
        <nav x-data="{ mobileMenuOpen: false }" class="fixed top-0 left-0 right-0 z-50 bg-white/85 dark:bg-gray-900/85 backdrop-blur-xl border-b border-gray-200 dark:border-gray-800">
            <div class="px-4 sm:px-6 lg:px-8 flex justify-between items-center h-16">
                <!-- Logo -->
                <div class="flex items-center">
                    <div class="w-8 h-8 bg-gradient-to-br from-green-500 to-green-600 rounded-lg flex items-center justify-center">
                        <span class="text-white font-bold text-lg">K</span>
                    </div>
                    <span class="ml-2 text-xl font-bold text-green-600">Klasiz.fun</span>
                </div>
                
                <!-- Desktop Menu -->
                <div class="hidden md:flex items-center space-x-4">
                    <button @click="darkMode = !darkMode" class="p-2 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700">
                        <Moon x-show="!darkMode" class="w-4 h-4" />
                        <Sun x-show="darkMode" class="w-4 h-4" />
                    </button>
                    <button @click="showModal('login')" class="px-3 py-2 rounded-lg text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 font-medium">
                        Login
                    </button>
                    <button @click="showModal('signup')" class="px-4 py-2 rounded-lg bg-gradient-to-r from-green-600 to-green-700 text-white hover:from-green-700 hover:to-green-800 font-medium flex items-center">
                        <Sparkles class="w-3.5 h-3.5 mr-1" /> Sign Up
                    </button>
                </div>
                
                <!-- Mobile Menu Button -->
                <div class="md:hidden relative">
                    <button @click="mobileMenuOpen = !mobileMenuOpen" class="p-2 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400">
                        <MoreVertical class="w-5 h-5" />
                    </button>
                    <div x-show="mobileMenuOpen" @click.away="mobileMenuOpen = false" class="absolute right-0 top-full mt-2 w-48 bg-white dark:bg-gray-900 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 p-2">
                        <button @click="showModal('signup'); mobileMenuOpen = false" class="w-full px-3 py-2 rounded-lg bg-gradient-to-r from-green-600 to-green-700 text-white flex items-center">
                            <Sparkles class="w-4 h-4 mr-2" /> Sign Up
                        </button>
                        <button @click="showModal('login'); mobileMenuOpen = false" class="w-full px-3 py-2 rounded-lg text-gray-700 dark:text-gray-300 flex items-center">
                            <LogIn class="w-4 h-4 mr-2" /> Login
                        </button>
                    </div>
                </div>
            </div>
        </nav>

        <!-- RIGHT NAV DOTS (Desktop) -->
        <div class="hidden md:flex fixed right-6 top-1/2 -translate-y-1/2 flex-col gap-2.5 z-40">
            <template x-for="(label, i) in ['Home', 'Features', 'Games', 'Reviews', 'Start']" x-bind:key="i">
                <button @click="scrollToSlide(i)" x-bind:title="label" class="w-2 h-2 rounded-full bg-gray-300 dark:bg-gray-600 hover:bg-green-500 transition-all" x-bind:class="activeSlide === i ? 'w-7 bg-green-500' : ''"></button>
            </template>
        </div>

        <!-- SCROLL-SNAP CONTAINER -->
        <div class="h-screen overflow-y-scroll scroll-snap-y-mandatory" x-ref="scrollContainer" x-init="$el.style.scrollBehavior = 'smooth'">
            
            <!-- SLIDE 1: HERO -->
            <section class="h-screen scroll-snap-start flex md:flex-row items-center justify-center gap-8 md:gap-20 relative overflow-hidden bg-gradient-to-br from-gray-50 to-green-50 dark:from-gray-900 dark:to-green-900 pt-20 px-6 md:px-20 pb-10">
                <!-- Animated Background Elements -->
                <div class="absolute top-1/2 left-1/3 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-green-500/10 rounded-full pointer-events-none animate-pulse"></div>
                <div class="absolute top-1/4 right-1/4 w-64 h-64 bg-blue-500/10 rounded-full pointer-events-none animate-bounce"></div>
                <div class="absolute bottom-1/4 left-1/4 w-48 h-48 bg-purple-500/10 rounded-full pointer-events-none animate-ping"></div>
                
                <!-- Floating Particles -->
                <div class="absolute inset-0 overflow-hidden pointer-events-none">
                    <template x-for="i in 6">
                        <div class="absolute w-2 h-2 bg-green-400/30 rounded-full animate-pulse" 
                             :style="`top: ${Math.random() * 100}%; left: ${Math.random() * 100}%; animation-delay: ${i * 0.5}s; animation-duration: ${2 + Math.random() * 3}s;`"></div>
                    </template>
                </div>
                
                <div class="relative z-10 flex-1 max-w-md md:max-w-lg text-center md:text-left">
                    <div class="inline-flex items-center gap-2 bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 px-4 py-2 rounded-full text-sm font-bold mb-6 border border-green-200 dark:border-green-800">
                        <Star class="w-3 h-3 fill-current" /> Modern Classroom Platform
                    </div>
                    <h1 class="text-4xl md:text-6xl font-black tracking-tight mb-5 text-gray-900 dark:text-white">
                        Modern Classroom<br />
                        <span class="text-gradient-animated">Made Simple</span>
                    </h1>
                    <p class="text-lg text-gray-600 dark:text-gray-300 mb-8 max-w-sm md:max-w-md">
                        Transform your classroom with gamification, real-time student tracking, and parent engagement. The all-in-one platform for modern teachers.
                    </p>
                    <div class="flex flex-col sm:flex-row gap-3 justify-center md:justify-start">
                        <button @click="showModal('signup')" class="group relative bg-gradient-to-r from-green-600 to-green-700 text-white px-7 py-3 rounded-xl font-bold hover:from-green-700 hover:to-green-800 flex items-center justify-center shadow-lg transform transition-all duration-300 hover:scale-105 hover:shadow-2xl">
                            <span class="absolute inset-0 rounded-xl bg-gradient-to-r from-green-400 to-blue-500 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
                            <span class="relative flex items-center">
                                <Sparkles class="w-4 h-4 mr-2 animate-spin-slow" /> Create Free Class <ArrowRight class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" />
                            </span>
                        </button>
                        <button @click="showModal('login')" class="group relative bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 px-7 py-3 rounded-xl font-bold hover:bg-gray-200 dark:hover:bg-gray-700 flex items-center justify-center border border-gray-200 dark:border-gray-600 transform transition-all duration-300 hover:scale-105 hover:shadow-xl">
                            <LogIn class="w-4 h-4 mr-2 group-hover:rotate-12 transition-transform" /> Login
                        </button>
                    </div>
                </div>
                
                <div class="relative z-10 flex-1 w-full max-w-sm md:max-w-md">
                    <div class="group bg-white rounded-2xl md:rounded-3xl shadow-2xl overflow-hidden border border-gray-100 transform transition-all duration-500 hover:scale-105 hover:shadow-3xl hover:rotate-1 animate-float">
                        <div class="flex">
                            <div class="hidden md:block w-16 bg-green-50 flex flex-col items-center pt-5 gap-3.5">
                                <div class="w-10 h-10 bg-green-500 rounded-xl flex items-center justify-center">
                                    <Layout class="w-5 h-5 text-white" />
                                </div>
                                <div class="w-10 h-10 bg-gray-200 rounded-xl flex items-center justify-center">
                                    <Trophy class="w-5 h-5 text-gray-500" />
                                </div>
                                <div class="w-10 h-10 bg-gray-200 rounded-xl flex items-center justify-center">
                                    <Settings class="w-5 h-5 text-gray-500" />
                                </div>
                            </div>
                            <div class="flex-1 p-3 md:p-4 flex flex-col gap-2.5">
                                <div class="flex justify-between items-center">
                                    <span class="text-sm md:text-base font-extrabold text-gray-900">Class 3A Mathematics</span>
                                    <div class="bg-green-100 border border-green-300 rounded-full px-2.5 py-0.5 text-xs font-bold text-green-700">Progress 85%</div>
                                </div>
                                <div class="grid grid-cols-3 gap-1.5 md:gap-2">
                                    <template x-for="(student, index) in displayStudents" x-bind:key="student.init">
                                        <div class="group bg-gray-50 border border-gray-200 rounded-lg p-2 md:p-3 flex flex-col items-center gap-1 transform transition-all duration-300 hover:scale-110 hover:bg-gradient-to-br hover:from-green-50 hover:to-blue-50 hover:border-green-300 hover:shadow-lg" 
                                             :style="`animation-delay: ${index * 0.1}s`">
                                            <div class="w-8 h-8 md:w-9 md:h-9 rounded-full bg-gradient-to-br from-gray-300 to-gray-400 flex items-center justify-center text-xs md:text-sm font-bold text-white group-hover:from-green-400 group-hover:to-blue-400 transition-all duration-300" x-text="student.init"></div>
                                            <span class="text-xs font-bold text-gray-900 group-hover:text-green-600 transition-colors duration-300" x-text="student.name"></span>
                                            <div class="bg-green-100 rounded-full px-1.5 py-0.5 text-xs font-bold text-green-700 group-hover:bg-green-500 group-hover:text-white transition-all duration-300" x-text="student.pts"></div>
                                        </div>
                                    </template>
                                </div>
                                <div class="flex justify-end">
                                    <div class="w-9 h-9 md:w-10 md:h-10 rounded-full bg-gray-900 flex items-center justify-center">
                                        <QrCode class="w-4 h-4 md:w-4.5 md:h-4.5 text-white" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Scroll Indicator -->
                <div class="absolute bottom-5 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5">
                    <div class="w-5.5 h-8.5 border-2 border-gray-300 dark:border-gray-600 rounded-full flex items-start justify-center pt-1.5">
                        <div class="w-0.5 h-1.5 bg-gray-400 dark:bg-gray-500 rounded-full"></div>
                    </div>
                    <span class="text-xs text-gray-400 dark:text-gray-500 font-bold tracking-wider uppercase">Scroll</span>
                </div>
            </section>

            <!-- SLIDE 2: FEATURES -->
            <section class="h-screen scroll-snap-start flex flex-col items-center justify-center bg-white dark:bg-gray-900 pt-20 px-5 md:px-12 pb-6">
                <div class="text-center mb-4 md:mb-6">
                    <h2 class="text-3xl md:text-5xl font-black tracking-tight mb-2 text-gray-900 dark:text-white">
                        Everything You Need in One Platform
                    </h2>
                    <p class="text-base md:text-lg text-gray-600 dark:text-gray-400 max-w-lg">
                        Powerful features designed for modern classrooms
                    </p>
                </div>
                
                <div class="grid grid-cols-2 md:grid-cols-3 gap-3.5 md:gap-4 max-w-5xl w-full">
                    <template x-for="(feature, i) in features" x-bind:key="i">
                        <div class="group bg-gradient-to-br from-gray-50 to-gray-100 dark:from-gray-800 dark:to-gray-700 border border-gray-200 dark:border-gray-600 rounded-2xl p-4 md:p-5 transform transition-all duration-500 hover:scale-105 hover:-translate-y-2 hover:shadow-2xl hover:rotate-1 hover:border-transparent hover:bg-gradient-to-br hover:from-white hover:to-green-50 dark:hover:from-gray-700 dark:hover:to-green-900/30"
                             :style="`animation-delay: ${i * 0.1}s`">
                            <div class="relative mb-3.5">
                                <div class="absolute inset-0 bg-gradient-to-br from-green-400 to-blue-500 rounded-xl opacity-0 group-hover:opacity-20 transition-opacity duration-300"></div>
                                <div class="relative w-12 h-12 bg-white dark:bg-gray-900 rounded-xl flex items-center justify-center text-2xl shadow-md group-hover:shadow-xl transition-all duration-300" x-bind:class="feature.bg">
                                    <span class="transform transition-transform duration-300 group-hover:scale-110 group-hover:rotate-12" x-text="feature.icon"></span>
                                </div>
                            </div>
                            <h3 class="text-sm md:text-base font-extrabold mb-1.5 text-gray-900 dark:text-white group-hover:text-green-600 dark:group-hover:text-green-400 transition-colors duration-300" x-text="feature.title"></h3>
                            <p class="text-xs md:text-sm text-gray-600 dark:text-gray-400 leading-relaxed group-hover:text-gray-700 dark:group-hover:text-gray-300 transition-colors duration-300" x-text="feature.desc"></p>
                        </div>
                    </template>
                </div>
            </section>

            <!-- SLIDE 3: GAMES -->
            <section class="h-screen scroll-snap-start flex md:flex-row items-center justify-center gap-8 md:gap-20 bg-gradient-to-br from-green-50 to-blue-50 dark:from-gray-900 dark:to-blue-900 pt-20 px-6 md:px-20 pb-10">
                <div class="flex-1 max-w-md">
                    <div class="inline-flex items-center gap-2 bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-400 px-4 py-2 rounded-full text-sm font-bold mb-6 border border-purple-200 dark:border-purple-800">
                        <Dices class="w-3 h-3" /> Interactive Learning Games
                    </div>
                    <h2 class="text-4xl md:text-6xl font-black tracking-tight mb-4 text-gray-900 dark:text-white">
                        Learning<br /><span class="bg-gradient-to-r from-purple-600 to-blue-600 text-transparent bg-clip-text">through play</span>
                    </h2>
                    <p class="text-lg text-gray-600 dark:text-gray-300 mb-8">
                        Engage students with fun, educational games that make learning exciting and memorable.
                    </p>
                    <button @click="showModal('signup')" class="bg-gradient-to-r from-purple-600 to-purple-700 text-white px-7 py-3 rounded-xl font-bold hover:from-purple-700 hover:to-purple-800 flex items-center shadow-lg">
                        Try Games Now <ArrowRight class="w-4 h-4 ml-1" />
                    </button>
                </div>
                
                <div class="flex-1 max-w-lg grid grid-cols-2 gap-3">
                    <template x-for="(game, i) in games" x-bind:key="i">
                        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-5 flex flex-col items-center gap-2 hover:shadow-lg transition-all hover:-translate-y-1">
                            <div class="text-4xl" x-text="game.emoji"></div>
                            <div class="text-sm font-bold text-gray-900 dark:text-white text-center" x-text="game.name"></div>
                            <div class="w-5 h-0.5 rounded-full" x-bind:class="game.color"></div>
                        </div>
                    </template>
                </div>
            </section>

            <!-- SLIDE 4: SOCIAL PROOF -->
            <section class="h-screen scroll-snap-start flex flex-col items-center justify-center bg-white dark:bg-gray-900 pt-20 px-5 md:px-12 pb-6">
                <div class="text-center mb-4 md:mb-6">
                    <h2 class="text-3xl md:text-5xl font-black tracking-tight mb-1.5 text-gray-900 dark:text-white">
                        Trusted by Teachers Worldwide
                    </h2>
                    <p class="text-base md:text-lg text-gray-600 dark:text-gray-400">Join thousands of educators transforming their classrooms</p>
                </div>
                
                <div class="grid grid-cols-3 gap-2 md:gap-3.5 max-w-3xl w-full mb-3 md:mb-4">
                    <template x-for="(stat, i) in stats" x-bind:key="i">
                        <div class="bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4 md:p-6 text-center">
                            <div class="text-2xl md:text-4xl font-black" x-bind:class="stat.color" x-text="stat.value"></div>
                            <div class="text-xs md:text-sm font-bold text-gray-600 dark:text-gray-400" x-text="stat.label"></div>
                        </div>
                    </template>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-3.5 max-w-4xl w-full">
                    <template x-for="(testimonial, i) in testimonials" x-bind:key="i">
                        <div class="bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-2xl p-5 md:p-6 flex flex-col gap-3">
                            <Quote class="w-5 h-5 opacity-50" x-bind:class="testimonial.color" />
                            <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed" x-text="testimonial.quote"></p>
                            <div class="flex items-center gap-2.5">
                                <div class="w-9 h-9 rounded-full bg-gradient-to-br from-green-500 to-green-600 flex items-center justify-center text-white text-sm font-bold" x-text="testimonial.initials"></div>
                                <div>
                                    <div class="font-bold text-sm text-gray-900 dark:text-white" x-text="testimonial.name"></div>
                                    <div class="text-xs text-gray-600 dark:text-gray-400" x-text="testimonial.role"></div>
                                </div>
                            </div>
                        </div>
                    </template>
                </div>
            </section>

            <!-- SLIDE 5: CTA + FOOTER -->
            <section class="h-screen scroll-snap-start flex flex-col items-center justify-center relative bg-gradient-to-br from-green-50 to-blue-50 dark:from-gray-900 dark:to-blue-900 pt-20 px-6 md:px-20 pb-10 overflow-hidden">
                <div class="absolute bottom-0 right-0 w-96 h-96 bg-green-500/10 rounded-full -translate-x-1/2 translate-y-1/2"></div>
                <div class="absolute top-0 left-0 w-96 h-96 bg-blue-500/10 rounded-full translate-x-1/2 -translate-y-1/2"></div>
                
                <div class="text-center z-10 max-w-3xl">
                    <h2 class="text-4xl md:text-6xl font-black tracking-tight mb-5 text-gray-900 dark:text-white">
                        Ready to Transform Your Classroom?
                    </h2>
                    <p class="text-lg md:text-xl text-gray-600 dark:text-gray-300 mb-10 max-w-lg mx-auto">
                        Join thousands of teachers already using Klasiz.fun to create engaging, effective learning environments.
                    </p>
                    <div class="flex flex-col sm:flex-row gap-3.5 justify-center mb-16">
                        <button @click="showModal('signup')" class="bg-gradient-to-r from-green-600 to-green-700 text-white px-8 py-4 rounded-xl font-bold hover:from-green-700 hover:to-green-800 flex items-center justify-center shadow-xl">
                            <Sparkles class="w-5 h-5 mr-2" /> Create Free Account <ArrowRight class="w-5 h-5 ml-1" />
                        </button>
                    </div>
                    
                    <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
                        <button class="text-gray-600 dark:text-gray-400 text-sm font-medium hover:text-gray-900 dark:hover:text-white">Privacy</button>
                        <button class="text-gray-600 dark:text-gray-400 text-sm font-medium hover:text-gray-900 dark:hover:text-white">Terms</button>
                        <button class="text-gray-600 dark:text-gray-400 text-sm font-medium hover:text-gray-900 dark:hover:text-white">FAQ</button>
                        <button class="text-gray-600 dark:text-gray-400 text-sm font-medium hover:text-gray-900 dark:hover:text-white">Guide</button>
                        <button class="text-gray-600 dark:text-gray-400 text-sm font-medium hover:text-gray-900 dark:hover:text-white">About</button>
                    </div>
                    <p class="text-xs text-gray-400 dark:text-gray-500 font-medium">
                        © 2024 Klasiz.fun - Modern Classroom Management Platform
                    </p>
                </div>
            </section>
        </div>

        <!-- MODAL SYSTEM -->
        <div x-show="modalMode" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4" @click.self="modalMode = null">
            <div class="bg-white dark:bg-gray-900 rounded-2xl w-full max-w-md shadow-2xl border border-gray-200 dark:border-gray-700">
                <div class="flex items-center justify-between p-6 border-b border-gray-200 dark:border-gray-700">
                    <h2 class="text-2xl font-black text-gray-900 dark:text-white">
                        <span x-show="modalMode === 'role'">Who are you?</span>
                        <span x-show="modalMode === 'student-login'">Student Login</span>
                        <span x-show="modalMode === 'signup'">Create Account</span>
                        <span x-show="modalMode === 'login'">Teacher Login</span>
                    </h2>
                    <button @click="modalMode = null" class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800">
                        <X class="w-5 h-5 text-gray-500" />
                    </button>
                </div>
                
                <div class="p-6">
                    <!-- Role Selection -->
                    <div x-show="modalMode === 'role'" class="space-y-3">
                        <button @click="modalMode = 'login'" class="w-full p-4 rounded-xl border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800 flex items-center gap-4">
                            <div class="w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-xl flex items-center justify-center">
                                <GraduationCap class="w-6 h-6 text-green-600 dark:text-green-400" />
                            </div>
                            <div class="text-left">
                                <h4 class="font-bold text-gray-900 dark:text-white">Teacher</h4>
                                <p class="text-sm text-gray-600 dark:text-gray-400">Manage classes and track progress</p>
                            </div>
                        </button>
                        <button @click="modalMode = 'student-login'" class="w-full p-4 rounded-xl border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800 flex items-center gap-4">
                            <div class="w-12 h-12 bg-teal-100 dark:bg-teal-900/30 rounded-xl flex items-center justify-center">
                                <BookOpen class="w-6 h-6 text-teal-600 dark:text-teal-400" />
                            </div>
                            <div class="text-left">
                                <h4 class="font-bold text-gray-900 dark:text-white">Student</h4>
                                <p class="text-sm text-gray-600 dark:text-gray-400">Access your learning portal</p>
                            </div>
                        </button>
                    </div>
                    
                    <!-- Student Login -->
                    <form x-show="modalMode === 'student-login'" @submit.prevent="handleStudentLogin" class="space-y-4">
                        <p class="text-gray-600 dark:text-gray-400 text-sm">Enter your 5-digit access code</p>
                        <input type="text" maxlength="5" placeholder="0 0 0 0 0" x-model="accessCode" 
                            class="w-full px-4 py-3 text-2xl font-bold text-center tracking-widest border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-green-500 focus:border-transparent" />
                        <button type="submit" class="w-full bg-green-600 text-white py-3 rounded-xl font-bold hover:bg-green-700">
                            Enter Portal
                        </button>
                        <button type="button" @click="modalMode = 'role'" class="w-full text-gray-600 dark:text-gray-400 text-sm hover:text-gray-900 dark:hover:text-white">
                            ← Back
                        </button>
                    </form>
                    
                    <!-- Teacher Login/Signup -->
                    <form x-show="modalMode === 'login' || modalMode === 'signup'" @submit.prevent="modalMode === 'signup' ? handleSignup() : handleLogin()" class="space-y-4">
                        <input type="email" placeholder="Email" x-model="email" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white" />
                        <input type="password" placeholder="Password" x-model="password" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white" />
                        
                        <button type="submit" class="w-full bg-green-600 text-white py-3 rounded-xl font-bold hover:bg-green-700">
                            <span x-show="modalMode === 'signup'">Create Account</span>
                            <span x-show="modalMode === 'login'">Login</span>
                        </button>
                        
                        <button type="button" @click="modalMode = modalMode === 'signup' ? 'login' : 'signup'" class="w-full text-gray-600 dark:text-gray-400 text-sm hover:text-gray-900 dark:hover:text-white">
