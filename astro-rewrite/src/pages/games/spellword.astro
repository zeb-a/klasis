---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Spell The Word - Klasiz.fun">
    <div id="spellword-game-container" class="min-h-screen bg-gray-50 dark:bg-gray-900">
        <!-- Inline the game component content -->
        <div 
          x-data="spellTheWordGame()"
          x-init="initGame()"
          class="max-w-4xl mx-auto p-6"
        >
          <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 shadow-lg">
            <!-- Game Header -->
            <div class="p-6 border-b border-gray-200 dark:border-gray-700">
              <div class="flex items-center justify-between">
                <div class="flex items-center space-x-4">
                  <div class="w-12 h-12 bg-green-100 dark:bg-green-900 rounded-lg flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-green-600 dark:text-green-400"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                  </div>
                  <div>
                    <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Spell The Word</h2>
                    <p class="text-gray-600 dark:text-gray-400">Listen, look, and spell correctly!</p>
                  </div>
                </div>
                <div class="text-center">
                  <div class="text-2xl font-bold text-green-600 dark:text-green-400" x-text="score"></div>
                  <div class="text-sm text-gray-500 dark:text-gray-400">Points</div>
                </div>
              </div>
            </div>

            <!-- Game Area -->
            <div class="p-6">
              <!-- Waiting State -->
              <template x-if="gameState === 'waiting'">
                <div class="text-center py-12">
                  <div class="w-24 h-24 bg-green-100 dark:bg-green-900 rounded-full flex items-center justify-center mx-auto mb-6">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-12 h-12 text-green-600 dark:text-green-400"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                  </div>
                  <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Ready to practice spelling?</h3>
                  <p class="text-gray-600 dark:text-gray-400 mb-6">Look at the image, listen to the word, and spell it correctly!</p>
                  <button
                    @click="startGame"
                    class="bg-green-600 text-white px-8 py-3 rounded-lg hover:bg-green-700 transition-colors text-lg font-semibold"
                  >
                    Start Game
                  </button>
                </div>
              </template>

              <!-- Playing State -->
              <template x-if="gameState === 'playing'">
                <div>
                  <!-- Word Display -->
                  <div class="text-center mb-8">
                    <div class="text-8xl mb-4" x-text="currentImage"></div>
                    <button
                      @click="playSound"
                      class="bg-blue-100 dark:bg-blue-900 text-blue-600 dark:text-blue-400 px-4 py-2 rounded-lg hover:bg-blue-200 dark:hover:bg-blue-800 transition-colors mb-4 flex items-center mx-auto"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 mr-2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>
                      Hear the Word
                    </button>
                    
                    <!-- Hint -->
                    <template x-if="showHint">
                      <div class="bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-700 rounded-lg p-3 mb-4">
                        <p class="text-yellow-800 dark:text-yellow-300">
                          <strong>Hint:</strong> <span x-text="getHint()"></span>
                        </p>
                      </div>
                    </template>
                  </div>

                  <!-- Input Area -->
                  <div class="mb-6">
                    <div class="flex justify-center mb-4">
                      <input
                        type="text"
                        x-model="userInput"
                        @keydown.enter="checkSpelling"
                        placeholder="Type your spelling here..."
                        :disabled="feedback !== ''"
                        class="w-full max-w-md px-4 py-3 text-lg border-2 border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent text-center bg-white dark:bg-gray-700 text-gray-900 dark:text-white"
                      />
                    </div>

                    <!-- Feedback -->
                    <template x-if="feedback === 'correct'">
                      <div class="text-center mb-4">
                        <div class="inline-flex items-center bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-300 px-4 py-2 rounded-lg">
                          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 mr-2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                          Correct! Well done!
                        </div>
                      </div>
                    </template>

                    <template x-if="feedback === 'incorrect'">
                      <div class="text-center mb-4">
                        <div class="inline-flex items-center bg-red-100 dark:bg-red-900 text-red-800 dark:text-red-300 px-4 py-2 rounded-lg">
                          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 mr-2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                          Try again!
                        </div>
                        <p class="text-gray-500 dark:text-gray-400 mt-2">The correct spelling was: <strong x-text="currentWord"></strong></p>
                      </div>
                    </template>

                    <!-- Action Buttons -->
                    <div class="flex justify-center gap-4">
                      <button
                        @click="checkSpelling"
                        :disabled="feedback === 'correct' || userInput.trim() === ''"
                        class="bg-green-600 text-white px-6 py-2 rounded-lg hover:bg-green-700 transition-colors disabled:bg-gray-300 disabled:cursor-not-allowed"
                      >
                        Check Spelling
                      </button>
                      <button
                        @click="toggleHint"
                        class="bg-yellow-100 dark:bg-yellow-900 text-yellow-700 dark:text-yellow-300 px-6 py-2 rounded-lg hover:bg-yellow-200 dark:hover:bg-yellow-800 transition-colors"
                      >
                        <span x-text="showHint ? 'Hide Hint' : 'Show Hint'"></span>
                      </button>
                      <button
                        @click="nextWord"
                        class="bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 px-6 py-2 rounded-lg hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors"
                      >
                        Skip Word
                      </button>
                    </div>
                  </div>
                </div>
              </template>

              <!-- Finished State -->
              <template x-if="gameState === 'finished'">
                <div class="text-center py-12">
                  <div class="w-24 h-24 bg-green-100 dark:bg-green-900 rounded-full flex items-center justify-center mx-auto mb-6">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-12 h-12 text-green-600 dark:text-green-400"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                  </div>
                  <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">Great Practice!</h3>
                  <p class="text-3xl font-bold text-green-600 dark:text-green-400 mb-6">Final Score: <span x-text="score"></span></p>
                  <button
                    @click="startGame"
                    class="bg-green-600 text-white px-8 py-3 rounded-lg hover:bg-green-700 transition-colors text-lg font-semibold"
                  >
                    Practice Again
                  </button>
                </div>
              </template>
            </div>
          </div>
        </div>
        
        <script>
        function spellTheWordGame() {
          return {
            gameState: 'waiting',
            score: 0,
            currentWord: '',
            currentImage: '',
            userInput: '',
            feedback: '',
            showHint: false,
            
            words: [
              { word: 'APPLE', image: '🍎', hint: 'A red or green fruit' },
              { word: 'SCHOOL', image: '🏫', hint: 'Place where you learn' },
              { word: 'RAINBOW', image: '🌈', hint: 'Colorful arc in the sky' },
              { word: 'BUTTERFLY', image: '🦋', hint: 'Colorful flying insect' },
              { word: 'MOUNTAIN', image: '🏔️', hint: 'Very tall landform' },
              { word: 'OCEAN', image: '🌊', hint: 'Large body of water' },
              { word: 'FLOWER', image: '🌸', hint: 'Colorful plant bloom' },
              { word: 'GUITAR', image: '🎸', hint: 'Musical instrument with strings' }
            ],

            initGame() {
              // Initialize if needed
            },

            startGame() {
              const randomWord = this.words[Math.floor(Math.random() * this.words.length)];
              this.currentWord = randomWord.word;
              this.currentImage = randomWord.image;
              this.userInput = '';
              this.feedback = '';
              this.showHint = false;
              this.score = 0;
              this.gameState = 'playing';
              
              setTimeout(() => {
                const input = document.querySelector('input[type="text"]');
                if (input) input.focus();
              }, 100);
            },

            checkSpelling() {
              if (this.userInput.toUpperCase() === this.currentWord) {
                this.feedback = 'correct';
                this.score += this.currentWord.length * 5;
                setTimeout(() => {
                  this.nextWord();
                }, 2000);
              } else {
                this.feedback = 'incorrect';
                setTimeout(() => {
                  this.feedback = '';
                }, 1500);
              }
            },

            nextWord() {
              const randomWord = this.words[Math.floor(Math.random() * this.words.length)];
              this.currentWord = randomWord.word;
              this.currentImage = randomWord.image;
              this.userInput = '';
              this.feedback = '';
              this.showHint = false;
            },

            toggleHint() {
              this.showHint = !this.showHint;
            },

            getHint() {
              const wordObj = this.words.find(w => w.word === this.currentWord);
              return wordObj ? wordObj.hint : '';
            },

            playSound() {
              const utterance = new SpeechSynthesisUtterance(this.currentWord);
              utterance.rate = 0.8;
              speechSynthesis.speak(utterance);
            }
          };
        }
        </script>
    </div>
</MainLayout>
