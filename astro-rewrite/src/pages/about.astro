---
import MainLayout from '../layouts/MainLayout.astro';
import { Heart, ArrowRight, GraduationCap, Code, TrendingUp, Shield, Clock, BarChart3, Palette, Award, Mail } from 'lucide-react';
---

<MainLayout title="About Klasiz.fun - Classroom Tools for Teachers" description="Learn how Klasiz.fun helps teachers run engaging classes with behavior points, assignments, reports, and games.">
    <div class="min-h-screen bg-gray-50 dark:bg-gray-900" x-data="{ isDark: false }" x-init="isDark = localStorage.getItem('theme') === 'dark'">
        <!-- Navbar -->
        <nav class="fixed top-0 left-0 right-0 z-50 bg-white/95 dark:bg-gray-900/95 backdrop-blur-xl border-b border-gray-200 dark:border-gray-800">
            <div class="px-4 sm:px-6 lg:px-8 flex justify-between items-center h-16">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 bg-gradient-to-br from-pink-500 to-pink-600 rounded-lg flex items-center justify-center">
                        <Heart class="w-5 h-5 text-white" />
                    </div>
                    <span class="text-xl font-bold text-gray-900 dark:text-white">Klasiz.fun</span>
                </div>
                <a href="/" class="px-4 py-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 font-medium flex items-center gap-2 transition-all">
                    <ArrowRight class="w-4 h-4" />
                    <span class="hidden sm:inline">Back to Home</span>
                    <span class="sm:hidden">Back</span>
                </a>
            </div>
        </nav>

        <!-- Hero Section -->
        <section class="pt-24 pb-12 px-4 sm:px-6 lg:px-8 text-center bg-gradient-to-br from-gray-50 to-pink-50 dark:from-gray-900 dark:to-pink-900/20">
            <div class="max-w-4xl mx-auto">
                <div class="w-20 h-20 bg-gradient-to-br from-pink-500 to-pink-600 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-xl shadow-pink-500/30">
                    <Heart class="w-10 h-10 text-white" />
                </div>
                <h1 class="text-4xl sm:text-5xl font-black mb-4 text-gray-900 dark:text-white">
                    About <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-600 to-pink-500">Klasiz.fun</span>
                </h1>
                <p class="text-lg text-gray-600 dark:text-gray-300 max-w-2xl mx-auto leading-relaxed">
                    We're on a mission to help teachers run <strong>calmer, more joyful classes</strong> with modern tools that make classroom management simple and effective.
                </p>
            </div>
        </section>

        <!-- Story Section -->
        <section class="py-16 px-4 sm:px-6 lg:px-8">
            <div class="max-w-4xl mx-auto">
                <h2 class="text-3xl font-bold text-center mb-12 text-gray-900 dark:text-white">Our Story</h2>
                
                <!-- Problem Section -->
                <div class="bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-xl border border-gray-200 dark:border-gray-700 mb-8">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="p-2 rounded-lg bg-red-100 dark:bg-red-900/30">
                            <Heart class="w-6 h-6 text-red-600" />
                        </div>
                        <h3 class="text-2xl font-bold text-red-600">We were tired of:</h3>
                    </div>
                    <ul class="space-y-4">
                        <li class="flex items-start gap-3">
                            <span class="w-6 h-6 rounded-full bg-red-100 dark:bg-red-900/30 text-red-600 flex items-center justify-center text-sm font-bold flex-shrink-0 mt-0.5">✕</span>
                            <span class="text-gray-700 dark:text-gray-300">Managing attendance on paper spreadsheets</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="w-6 h-6 rounded-full bg-red-100 dark:bg-red-900/30 text-red-600 flex items-center justify-center text-sm font-bold flex-shrink-0 mt-0.5">✕</span>
                            <span class="text-gray-700 dark:text-gray-300">Writing points on whiteboard</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="w-6 h-6 rounded-full bg-red-100 dark:bg-red-900/30 text-red-600 flex items-center justify-center text-sm font-bold flex-shrink-0 mt-0.5">✕</span>
                            <span class="text-gray-700 dark:text-gray-300">Losing track of student behavior</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="w-6 h-6 rounded-full bg-red-100 dark:bg-red-900/30 text-red-600 flex items-center justify-center text-sm font-bold flex-shrink-0 mt-0.5">✕</span>
                            <span class="text-gray-700 dark:text-gray-300">Using complicated school platforms</span>
                        </li>
                    </ul>
                </div>

                <!-- Solution Section -->
                <div class="bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-xl border border-gray-200 dark:border-gray-700">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="p-2 rounded-lg bg-green-100 dark:bg-green-900/30">
                            <GraduationCap class="w-6 h-6 text-green-600" />
                        </div>
                        <h3 class="text-2xl font-bold text-green-600">So we built:</h3>
                    </div>
                    <ul class="space-y-4">
                        <li class="flex items-start gap-3">
                            <span class="w-6 h-6 rounded-full bg-green-100 dark:bg-green-900/30 text-green-600 flex items-center justify-center text-sm font-bold flex-shrink-0 mt-0.5">✓</span>
                            <span class="text-gray-700 dark:text-gray-300"><strong>One-click behavior tracking</strong> with customizable WOW and NO-NO cards</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="w-6 h-6 rounded-full bg-green-100 dark:bg-green-900/30 text-green-600 flex items-center justify-center text-sm font-bold flex-shrink-0 mt-0.5">✓</span>
                            <span class="text-gray-700 dark:text-gray-300"><strong>Live parent portal</strong> so families stay informed</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="w-6 h-6 rounded-full bg-green-100 dark:bg-green-900/30 text-green-600 flex items-center justify-center text-sm font-bold flex-shrink-0 mt-0.5">✓</span>
                            <span class="text-gray-700 dark:text-gray-300"><strong>Engaging educational games</strong> that students love</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="w-6 h-6 rounded-full bg-green-100 dark:bg-green-900/30 text-green-600 flex items-center justify-center text-sm font-bold flex-shrink-0 mt-0.5">✓</span>
                            <span class="text-gray-700 dark:text-gray-300"><strong>Beautiful reports</strong> for data-driven decisions</span>
                        </li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- Values Section -->
        <section class="py-16 px-4 sm:px-6 lg:px-8 bg-white dark:bg-gray-800">
            <div class="max-w-6xl mx-auto">
                <h2 class="text-3xl font-bold text-center mb-12 text-gray-900 dark:text-white">Our Values</h2>
                <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
                    <div class="bg-gray-50 dark:bg-gray-900 rounded-xl p-6 text-center">
                        <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center mx-auto mb-4">
                            <Shield class="w-6 h-6 text-blue-600" />
                        </div>
                        <h3 class="font-bold text-gray-900 dark:text-white mb-2">Privacy First</h3>
                        <p class="text-sm text-gray-600 dark:text-gray-400">COPPA compliant with industry-standard encryption</p>
                    </div>
                    <div class="bg-gray-50 dark:bg-gray-900 rounded-xl p-6 text-center">
                        <div class="w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-lg flex items-center justify-center mx-auto mb-4">
                            <Award class="w-6 h-6 text-green-600" />
                        </div>
                        <h3 class="font-bold text-gray-900 dark:text-white mb-2">Always Free</h3>
                        <p class="text-sm text-gray-600 dark:text-gray-400">Core features free for all teachers forever</p>
                    </div>
                    <div class="bg-gray-50 dark:bg-gray-900 rounded-xl p-6 text-center">
                        <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900/30 rounded-lg flex items-center justify-center mx-auto mb-4">
                            <Palette class="w-6 h-6 text-purple-600" />
                        </div>
                        <h3 class="font-bold text-gray-900 dark:text-white mb-2">Beautiful Design</h3>
                        <p class="text-sm text-gray-600 dark:text-gray-400">Intuitive interface that teachers love</p>
                    </div>
                    <div class="bg-gray-50 dark:bg-gray-900 rounded-xl p-6 text-center">
                        <div class="w-12 h-12 bg-orange-100 dark:bg-orange-900/30 rounded-lg flex items-center justify-center mx-auto mb-4">
                            <TrendingUp class="w-6 h-6 text-orange-600" />
                        </div>
                        <h3 class="font-bold text-gray-900 dark:text-white mb-2">Data-Driven</h3>
                        <p class="text-sm text-gray-600 dark:text-gray-400">Real insights to improve your classroom</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Team Section -->
        <section class="py-16 px-4 sm:px-6 lg:px-8">
            <div class="max-w-4xl mx-auto text-center">
                <h2 class="text-3xl font-bold mb-8 text-gray-900 dark:text-white">Built by Educators</h2>
                <p class="text-gray-600 dark:text-gray-300 mb-8 max-w-2xl mx-auto">
                    Our team includes former teachers, education technology experts, and parents who understand the challenges of modern classrooms.
                </p>
                <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
                    <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-lg border border-gray-200 dark:border-gray-700">
                        <img src="/team-sarah.jpg" alt="Sarah" class="w-20 h-20 rounded-full mx-auto mb-4 object-cover" onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22%3E%3Crect fill=%22%23e0e7ff%22 width=%22100%22 height=%22100%22/%3E%3Ctext x=%2250%22 y=%2255%22 text-anchor=%22middle%22 font-size=%2240%22 fill=%22%234f46e5%22%3ES%3C/text%3E%3C/svg%3E'" />
                        <h3 class="font-bold text-gray-900 dark:text-white">Sarah</h3>
                        <p class="text-sm text-gray-600 dark:text-gray-400">Former Teacher</p>
                    </div>
                    <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-lg border border-gray-200 dark:border-gray-700">
                        <img src="/team-mike.jpg" alt="Mike" class="w-20 h-20 rounded-full mx-auto mb-4 object-cover" onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22%3E%3Crect fill=%22%23dcfce7%22 width=%22100%22 height=%22100%22/%3E%3Ctext x=%2250%22 y=%2255%22 text-anchor=%22middle%22 font-size=%2240%22 fill=%22%2316a34a%22%3EM%3C/text%3E%3C/svg%3E'" />
                        <h3 class="font-bold text-gray-900 dark:text-white">Mike</h3>
                        <p class="text-sm text-gray-600 dark:text-gray-400">EdTech Developer</p>
                    </div>
                    <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-lg border border-gray-200 dark:border-gray-700">
                        <img src="/team-emily.jpg" alt="Emily" class="w-20 h-20 rounded-full mx-auto mb-4 object-cover" onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22%3E%3Crect fill=%22%2#fef3c7%22 width=%22100%22 height=%22100%22/%3E%3Ctext x=%2250%22 y=%2255%22 text-anchor=%22middle%22 font-size=%2240%22 fill=%22%2#d97706%22%3EE%3C/text%3E%3C/svg%3E'" />
                        <h3 class="font-bold text-gray-900 dark:text-white">Emily</h3>
                        <p class="text-sm text-gray-600 dark:text-gray-400">UX Designer</p>
                    </div>
                    <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-lg border border-gray-200 dark:border-gray-700">
                        <img src="/team-david.jpg" alt="David" class="w-20 h-20 rounded-full mx-auto mb-4 object-cover" onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22%3E%3Crect fill=%22%2#fee2e2%22 width=%22100%22 height=%22100%22/%3E%3Ctext x=%2250%22 y=%2255%22 text-anchor=%22middle%22 font-size=%2240%22 fill=%22%2#dc2626%22%3ED%3C/text%3E%3C/svg%3E'" />
                        <h3 class="font-bold text-gray-900 dark:text-white">David</h3>
                        <p class="text-sm text-gray-600 dark:text-gray-400">Parent & Advisor</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="py-16 px-4 sm:px-6 lg:px-8 bg-gradient-to-br from-green-500 to-green-600">
            <div class="max-w-4xl mx-auto text-center">
                <h2 class="text-3xl font-bold text-white mb-4">Ready to Transform Your Classroom?</h2>
                <p class="text-green-100 mb-8 max-w-2xl mx-auto">Join thousands of teachers using Klasiz.fun to create engaging, well-managed classrooms.</p>
                <a href="/" class="inline-flex items-center gap-2 bg-white text-green-600 px-8 py-4 rounded-xl font-bold hover:bg-green-50 transition-all shadow-xl">
                    Get Started Free
                    <ArrowRight class="w-5 h-5" />
                </a>
            </div>
        </section>

        <!-- Footer -->
        <footer class="bg-white dark:bg-gray-900 border-t border-gray-200 dark:border-gray-800 py-12 px-4 sm:px-6 lg:px-8">
            <div class="max-w-6xl mx-auto">
                <div class="grid md:grid-cols-4 gap-8 mb-8">
                    <div>
                        <div class="flex items-center gap-2 mb-4">
                            <div class="w-8 h-8 bg-gradient-to-br from-green-500 to-green-600 rounded-lg flex items-center justify-center">
                                <span class="text-white font-bold">K</span>
                            </div>
                            <span class="text-lg font-bold text-gray-900 dark:text-white">Klasiz.fun</span>
                        </div>
                        <p class="text-sm text-gray-600 dark:text-gray-400">Modern classroom management made simple.</p>
                    </div>
                    <div>
                        <h4 class="font-bold text-gray-900 dark:text-white mb-4">Product</h4>
                        <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400">
                            <li><a href="/classes" class="hover:text-green-600">Classes</a></li>
                            <li><a href="/dashboard" class="hover:text-green-600">Dashboard</a></li>
                            <li><a href="/games/tornado" class="hover:text-green-600">Games</a></li>
                        </ul>
                    </div>
                    <div>
                        <h4 class="font-bold text-gray-900 dark:text-white mb-4">Resources</h4>
                        <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400">
                            <li><a href="/guide" class="hover:text-green-600">Help Guide</a></li>
                            <li><a href="/faq" class="hover:text-green-600">FAQ</a></li>
                            <li><a href="/about" class="hover:text-green-600">About</a></li>
                        </ul>
                    </div>
                    <div>
                        <h4 class="font-bold text-gray-900 dark:text-white mb-4">Legal</h4>
                        <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400">
                            <li><a href="/privacy" class="hover:text-green-600">Privacy</a></li>
                            <li><a href="/terms" class="hover:text-green-600">Terms</a></li>
                        </ul>
                    </div>
                </div>
                <div class="border-t border-gray-200 dark:border-gray-800 pt-8 text-center text-sm text-gray-600 dark:text-gray-400">
                    © 2024 Klasiz.fun. All rights reserved.
                </div>
            </div>
        </footer>
    </div>
</MainLayout>
